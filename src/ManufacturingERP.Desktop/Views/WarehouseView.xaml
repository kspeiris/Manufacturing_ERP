<UserControl x:Class="ManufacturingERP.Desktop.Views.WarehouseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Warehouse Control Center" FontSize="30" FontWeight="Bold" Margin="0,0,0,18" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Stock Adjustment" Style="{StaticResource CardTitleText}" />
                    <TextBlock Text="Product" Style="{StaticResource FormLabel}" />
                    <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" DisplayMemberPath="Name" />
                    <TextBlock Text="Warehouse" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                    <ComboBox ItemsSource="{Binding Warehouses}" SelectedItem="{Binding SelectedWarehouse}" DisplayMemberPath="Name" />
                    <TextBlock Text="Adjustment Qty (+/-)" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                    <TextBox Text="{Binding AdjustmentQty}" />
                    <TextBlock Text="Reason" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                    <TextBox Text="{Binding Reason}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" />
                    <WrapPanel Margin="0,16,0,0">
                        <Button Content="Save Adjustment" Command="{Binding SaveAdjustmentCommand}" Margin="0,0,8,0" />
                        <Button Content="Refresh Stock" Command="{Binding RefreshStockCommand}" />
                    </WrapPanel>
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,14,0,0" Foreground="#2563EB" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Current Stock" Style="{StaticResource CardTitleText}" />
                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="{Binding TotalQuantityOnHand, StringFormat=Total Qty: {0:N2}}" Margin="0,0,18,0" Foreground="#334155" />
                            <TextBlock Text="{Binding TotalStockValue, StringFormat=Total Value: {0:N2}}" Foreground="#334155" />
                        </WrapPanel>
                        <DataGrid ItemsSource="{Binding StockRows}" AutoGenerateColumns="False" CanUserAddRows="False" Height="240">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding ProductCode}" Width="110" />
                                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                                <DataGridTextColumn Header="Warehouse" Binding="{Binding WarehouseName}" Width="180" />
                                <DataGridTextColumn Header="Qty" Binding="{Binding QuantityOnHand}" Width="100" />
                                <DataGridTextColumn Header="Cost" Binding="{Binding CostPrice}" Width="100" />
                                <DataGridTextColumn Header="Value" Binding="{Binding StockValue}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Stock Movement History" Style="{StaticResource CardTitleText}" Margin="0,18,0,8" />
                        <DataGrid ItemsSource="{Binding MovementRows}" AutoGenerateColumns="False" CanUserAddRows="False" Height="250">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding TransactionDate}" Width="160" />
                                <DataGridTextColumn Header="Code" Binding="{Binding ProductCode}" Width="100" />
                                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                                <DataGridTextColumn Header="Warehouse" Binding="{Binding WarehouseName}" Width="150" />
                                <DataGridTextColumn Header="Type" Binding="{Binding TransactionType}" Width="110" />
                                <DataGridTextColumn Header="In" Binding="{Binding QuantityIn}" Width="90" />
                                <DataGridTextColumn Header="Out" Binding="{Binding QuantityOut}" Width="90" />
                                <DataGridTextColumn Header="Reference" Binding="{Binding ReferenceNo}" Width="170" />
                                <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="220" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
