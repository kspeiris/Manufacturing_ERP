<UserControl x:Class="ManufacturingERP.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource SectionCard}" Background="#0F172A" BorderThickness="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.7*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Executive Dashboard" FontSize="32" FontWeight="Bold" Foreground="White" />
                        <TextBlock Text="Track sales, inventory, receivables, payables, and production from one clean operating snapshot." Foreground="#CBD5E1" Margin="0,8,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="#1E293B" CornerRadius="18" Padding="18" Margin="18,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Today Sales" Foreground="#93C5FD" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Summary.TodaySales, StringFormat=N2}" FontSize="30" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="{Binding Summary.OutstandingBalance, StringFormat=Outstanding {0:N2}}" Foreground="#CBD5E1" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <UniformGrid Columns="4" Margin="0,0,0,18">
                <Border Style="{StaticResource SectionCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Customers" Style="{StaticResource CardTitleText}" /><TextBlock Text="{Binding Summary.TotalCustomers}" Style="{StaticResource MetricValueText}" /></StackPanel></Border>
                <Border Style="{StaticResource SectionCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Products" Style="{StaticResource CardTitleText}" /><TextBlock Text="{Binding Summary.TotalProducts}" Style="{StaticResource MetricValueText}" /></StackPanel></Border>
                <Border Style="{StaticResource SectionCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Vehicles" Style="{StaticResource CardTitleText}" /><TextBlock Text="{Binding Summary.TotalVehicles}" Style="{StaticResource MetricValueText}" /></StackPanel></Border>
                <Border Style="{StaticResource SectionCard}"><StackPanel><TextBlock Text="Receivables" Style="{StaticResource CardTitleText}" /><TextBlock Text="{Binding Summary.Analytics.CustomerReceivables, StringFormat=N2}" Style="{StaticResource MetricValueText}" /></StackPanel></Border>
            </UniformGrid>

            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,16"><StackPanel><TextBlock Text="Monthly Sales" Style="{StaticResource CardTitleText}" /><TextBlock Text="{Binding Summary.Analytics.MonthlySales, StringFormat=N2}" Style="{StaticResource MetricValueText}" /></StackPanel></Border>
                <Border Grid.Column="1" Style="{StaticResource SectionCard}" Margin="0,0,16,16"><StackPanel><TextBlock Text="Collections This Month" Style="{StaticResource CardTitleText}" /><TextBlock Text="{Binding Summary.Analytics.CollectionsThisMonth, StringFormat=N2}" Style="{StaticResource MetricValueText}" /></StackPanel></Border>
                <Border Grid.Column="2" Style="{StaticResource SectionCard}" Margin="0,0,0,16"><StackPanel><TextBlock Text="Inventory Value" Style="{StaticResource CardTitleText}" /><TextBlock Text="{Binding Summary.Analytics.InventoryValue, StringFormat=N2}" Style="{StaticResource MetricValueText}" /></StackPanel></Border>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0"><StackPanel><TextBlock Text="Customer Receivables" Style="{StaticResource CardTitleText}" /><TextBlock Text="{Binding Summary.Analytics.CustomerReceivables, StringFormat=N2}" Style="{StaticResource MetricValueText}" /></StackPanel></Border>
                <Border Grid.Column="1" Style="{StaticResource SectionCard}" Margin="0,0,16,0"><StackPanel><TextBlock Text="Supplier Payables" Style="{StaticResource CardTitleText}" /><TextBlock Text="{Binding Summary.Analytics.SupplierPayables, StringFormat=N2}" Style="{StaticResource MetricValueText}" /></StackPanel></Border>
                <Border Grid.Column="2" Style="{StaticResource SectionCard}"><StackPanel><TextBlock Text="Production Cost This Month" Style="{StaticResource CardTitleText}" /><TextBlock Text="{Binding Summary.Analytics.ProductionCostThisMonth, StringFormat=N2}" Style="{StaticResource MetricValueText}" /></StackPanel></Border>
            </Grid>

            <Border Style="{StaticResource SectionCard}" Margin="0,18,0,0">
                <StackPanel>
                    <TextBlock Text="Management Snapshot" Style="{StaticResource CardTitleText}" />
                    <TextBlock Text="Relative metric bars make it easier to compare the business drivers at a glance." Style="{StaticResource SubtleCaptionText}" />
                    <ItemsControl ItemsSource="{Binding ChartPoints}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <Border Grid.Column="1" Height="24" Background="#E2E8F0" CornerRadius="12" VerticalAlignment="Center">
                                        <Border Width="{Binding BarWidth}" Height="24" HorizontalAlignment="Left" Background="{Binding FillBrush}" CornerRadius="12" />
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Value, StringFormat=N2}" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
