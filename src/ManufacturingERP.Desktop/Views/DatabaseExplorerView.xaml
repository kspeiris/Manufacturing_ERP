<UserControl x:Class="ManufacturingERP.Desktop.Views.DatabaseExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Margin="0,0,0,8">
            <Border Style="{StaticResource HeroCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="1.2*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Database Explorer" Style="{StaticResource HeroTitleText}" />
                        <TextBlock Text="Browse live tables directly from the SQLite database." Style="{StaticResource HeroEyebrowText}" Margin="0,6,0,0" />
                        <TextBlock Text="This view reads the actual database behind the ERP and lets you inspect table contents, row counts, and current records without leaving the application." Style="{StaticResource HeroBodyText}" Margin="0,12,0,0" MaxWidth="760" />
                    </StackPanel>

                    <Border Grid.Column="1" Background="#172554" BorderBrush="#2563EB" BorderThickness="1" CornerRadius="18" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Current table" Foreground="#93C5FD" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding TableCaption}" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,10,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding StatusText}" Foreground="#CBD5E1" Margin="0,10,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Tables" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Select a table to inspect." Style="{StaticResource PageSubtitleText}" />
                        <Button Content="Refresh"
                                Command="{Binding RefreshCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,12,0,10" />
                        <ListBox ItemsSource="{Binding Tables}"
                                 SelectedItem="{Binding SelectedTable, Mode=TwoWay}"
                                 DisplayMemberPath="DisplayName"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Height="520">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" CornerRadius="12" Margin="0,0,0,6" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="#0F172A" />
                                            <TextBlock Text="{Binding TableName}" Foreground="#64748B" FontSize="12" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding RowCount, StringFormat={}{0:N0} rows}" Foreground="#2563EB" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource TableShellBorder}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{StaticResource TableToolbarBorder}" Margin="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding TableCaption}" Style="{StaticResource CardTitleText}" Margin="0" />
                                    <TextBlock Text="{Binding LoadedRowCount, StringFormat=Loaded rows: {0:N0}}" Style="{StaticResource PageSubtitleText}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding StatusText}"
                                           VerticalAlignment="Center"
                                           Foreground="#475569"
                                           TextWrapping="Wrap"
                                           MaxWidth="420" />
                            </Grid>
                        </Border>

                        <Border Margin="14,0,14,14" Background="#FFFFFF" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1">
                        <DataGrid ItemsSource="{Binding TableData}"
                                  AutoGenerateColumns="True"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="True"
                                  CanUserSortColumns="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  AlternationCount="2"
                                  MaxHeight="540"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </Border>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
