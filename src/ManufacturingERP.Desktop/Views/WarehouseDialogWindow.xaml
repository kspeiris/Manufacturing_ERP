<Window x:Class="ManufacturingERP.Desktop.Views.WarehouseDialogWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Warehouse" Height="460" Width="500" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="{StaticResource AppBackgroundBrush}">
    <Border Margin="20" Style="{StaticResource ViewRootCard}">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Warehouse" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Maintain the warehouse name, location, and active status in a clearer modal layout." Style="{StaticResource PageSubtitleText}" Margin="0,0,0,20" />
                    <TextBlock Text="Name" Style="{StaticResource FormLabel}" />
                    <TextBox Text="{Binding Name}" />
                    <TextBlock Text="Location" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Text="{Binding Location}" />
                    <CheckBox Content="Active" IsChecked="{Binding IsActive}" />
                </StackPanel>
            </ScrollViewer>
            <WrapPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Save" Width="110" Style="{StaticResource PrimaryActionButton}" Click="Save_Click" />
                <Button Content="Cancel" Width="110" Style="{StaticResource SecondaryActionButton}" Margin="0" Click="Cancel_Click" />
            </WrapPanel>
        </Grid>
    </Border>
</Window>
