<Window x:Class="ManufacturingERP.Desktop.Views.WarehouseDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Warehouse"
        Height="440"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EAF1FA">
    <Grid Margin="18">
        <Border Style="{StaticResource SectionCard}" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Warehouse Profile" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Capture storage-point identity and location details."
                               Style="{StaticResource PageSubtitleText}" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Name" Style="{StaticResource FormLabel}" />
                    <TextBox Text="{Binding Name}" materialDesign:HintAssist.Hint="Warehouse name" />
                    <TextBlock Text="Location" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                    <TextBox Text="{Binding Location}" materialDesign:HintAssist.Hint="Physical location" />
                    <CheckBox Content="Active" IsChecked="{Binding IsActive}" Margin="0,16,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="Save" Width="110" Margin="0,0,8,0" Click="Save_Click" />
                    <Button Content="Cancel" Width="110" Click="Cancel_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
