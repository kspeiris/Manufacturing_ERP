<UserControl x:Class="ManufacturingERP.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <DockPanel Margin="0,0,0,18">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Reporting Workspace" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Review recent operational data and launch exports from a more structured reporting hub."
                               Style="{StaticResource PageSubtitleText}" />
                </StackPanel>
                <Button Content="Reload"
                        Command="{Binding LoadCommand}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top" />
            </DockPanel>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource InlineStatCard}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Sales Rows" Style="{StaticResource InlineStatLabel}" />
                        <TextBlock Text="{Binding SalesRows.Count}" Style="{StaticResource InlineStatValue}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource InlineStatCard}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Purchase Rows" Style="{StaticResource InlineStatLabel}" />
                        <TextBlock Text="{Binding PurchaseRows.Count}" Style="{StaticResource InlineStatValue}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource UtilityPanel}">
                    <StackPanel>
                        <TextBlock Text="Export Status" Style="{StaticResource InlineStatLabel}" />
                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource UtilityPanel}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Export Actions" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Choose the required operational or finance output from this action shelf instead of hunting through tables."
                                   Style="{StaticResource PageSubtitleText}"
                                   Margin="0" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" ItemHeight="42">
                        <Button Content="Export Sales" Command="{Binding ExportSalesCommand}" Margin="0,0,8,8" />
                        <Button Content="Export Purchases" Command="{Binding ExportPurchasesCommand}" Margin="0,0,8,8" />
                        <Button Content="Export Customer Ledgers" Command="{Binding ExportCustomerLedgerSummaryCommand}" Margin="0,0,8,8" />
                        <Button Content="Export Supplier Ledgers" Command="{Binding ExportSupplierLedgerSummaryCommand}" Margin="0,0,8,8" />
                        <Button Content="Print Invoice (HTML)" Command="{Binding ExportInvoiceHtmlCommand}" Margin="0,0,8,8" />
                        <Button Content="Print PO (HTML)" Command="{Binding ExportPurchaseOrderHtmlCommand}" Margin="0,0,8,8" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="Recent Sales" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Validate invoicing, collection, and vehicle-sale activity before exporting."
                                   Style="{StaticResource PageSubtitleText}"
                                   Margin="0" />
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding SalesRows}" AutoGenerateColumns="False" CanUserAddRows="False" Height="220">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceNo}" Width="160" />
                            <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDate}" Width="150" />
                            <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*" />
                            <DataGridTextColumn Header="Vehicle" Binding="{Binding VehicleNo}" Width="130" />
                            <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount}" Width="120" />
                            <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount}" Width="120" />
                            <DataGridTextColumn Header="Type" Binding="{Binding SaleType}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="Recent Purchase Orders" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Monitor procurement flow and status changes before distributing reports."
                                   Style="{StaticResource PageSubtitleText}"
                                   Margin="0" />
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding PurchaseRows}" AutoGenerateColumns="False" CanUserAddRows="False" Height="220">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PO No" Binding="{Binding OrderNo}" Width="160" />
                            <DataGridTextColumn Header="Date" Binding="{Binding OrderDate}" Width="150" />
                            <DataGridTextColumn Header="Supplier" Binding="{Binding SupplierName}" Width="*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <TextBlock Text="Customer Ledger Summary" Style="{StaticResource CardTitleText}" />
                            <TextBlock Text="Highlight receivable exposure by customer." Style="{StaticResource PageSubtitleText}" Margin="0" />
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding CustomerLedgerSummaryRows}" AutoGenerateColumns="False" CanUserAddRows="False" Height="220">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding PartyCode}" Width="120" />
                                <DataGridTextColumn Header="Customer" Binding="{Binding PartyName}" Width="*" />
                                <DataGridTextColumn Header="Balance" Binding="{Binding Balance}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <TextBlock Text="Supplier Ledger Summary" Style="{StaticResource CardTitleText}" />
                            <TextBlock Text="Highlight payable exposure by supplier." Style="{StaticResource PageSubtitleText}" Margin="0" />
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding SupplierLedgerSummaryRows}" AutoGenerateColumns="False" CanUserAddRows="False" Height="220">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding PartyCode}" Width="120" />
                                <DataGridTextColumn Header="Supplier" Binding="{Binding PartyName}" Width="*" />
                                <DataGridTextColumn Header="Balance" Binding="{Binding Balance}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
