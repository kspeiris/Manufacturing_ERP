<UserControl x:Class="ManufacturingERP.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,8">
            <Border Style="{StaticResource HeroCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.4*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="Reporting Workspace" Style="{StaticResource HeroTitleText}" />
                        <TextBlock Text="Operational reporting hub" Style="{StaticResource HeroEyebrowText}" Margin="0,6,0,0" />
                        <TextBlock Text="Review recent operational data and launch exports from a more structured reporting hub."
                                   Style="{StaticResource HeroBodyText}" Margin="0,12,0,0" MaxWidth="700" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                        <Button Content="Reload" Command="{Binding LoadCommand}" Style="{StaticResource PageActionButton}" Margin="0" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,16"><StackPanel><TextBlock Text="Sales Rows" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding SalesRows.Count}" Style="{StaticResource InlineStatValue}" /><TextBlock Text="Recent sales records loaded for review." Style="{StaticResource PageSubtitleText}" /></StackPanel></Border>
                <Border Grid.Column="1" Style="{StaticResource SectionCard}" Margin="0,0,16,16"><StackPanel><TextBlock Text="Purchase Rows" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding PurchaseRows.Count}" Style="{StaticResource InlineStatValue}" /><TextBlock Text="Recent procurement rows in the report set." Style="{StaticResource PageSubtitleText}" /></StackPanel></Border>
                <Border Grid.Column="2" Style="{StaticResource SectionCard}" Margin="0,0,0,16"><StackPanel><TextBlock Text="Export Status" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding StatusMessage, TargetNullValue=Ready}" Style="{StaticResource InlineStatValue}" /><TextBlock Text="Latest reporting or export feedback." Style="{StaticResource PageSubtitleText}" /></StackPanel></Border>
            </Grid>

            <Border Style="{StaticResource UtilityPanel}">
                <WrapPanel>
                    <StackPanel Margin="0,0,20,12" Width="320">
                        <TextBlock Text="Export Actions" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Choose the required operational or finance output from this action shelf instead of hunting through tables."
                                   Style="{StaticResource PageSubtitleText}" Margin="0" />
                    </StackPanel>
                    <WrapPanel>
                        <Button Content="Export Sales" Command="{Binding ExportSalesCommand}" Style="{StaticResource PageActionButton}" />
                        <Button Content="Export Purchases" Command="{Binding ExportPurchasesCommand}" Style="{StaticResource PageActionButton}" />
                        <Button Content="Export Customer Ledgers" Command="{Binding ExportCustomerLedgerSummaryCommand}" Style="{StaticResource PageActionButton}" />
                        <Button Content="Export Supplier Ledgers" Command="{Binding ExportSupplierLedgerSummaryCommand}" Style="{StaticResource PageActionButton}" />
                        <Button Content="Print Invoice (HTML)" Command="{Binding ExportInvoiceHtmlCommand}" Style="{StaticResource PageActionButton}" />
                        <Button Content="Print PO (HTML)" Command="{Binding ExportPurchaseOrderHtmlCommand}" Style="{StaticResource PageActionButton}" Margin="0" />
                    </WrapPanel>
                </WrapPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}" VerticalAlignment="Top">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                        <TextBlock Text="Recent Sales" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Validate invoicing, collection, and vehicle-sale activity before exporting."
                                   Style="{StaticResource PageSubtitleText}" Margin="0" />
                    </StackPanel>
                    <Border Style="{StaticResource TableToolbarBorder}" DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Recent sales register with invoice, customer, and amount visibility."
                                       Style="{StaticResource PageSubtitleText}"
                                       VerticalAlignment="Center"
                                       Margin="0" />
                            <Border Grid.Column="1" Style="{StaticResource TableCountBadge}" Margin="12,0,0,0">
                                <TextBlock Text="{Binding SalesRows.Count, StringFormat=Total: {0}}" Style="{StaticResource TableCountText}" />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource TableShellBorder}" Padding="8">
                        <ScrollViewer Style="{StaticResource TableViewportScrollViewer}">
                        <DataGrid ItemsSource="{Binding SalesRows}" AutoGenerateColumns="False" CanUserAddRows="False" MaxHeight="260" MinWidth="900">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceNo}" Width="160" />
                                <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDate}" Width="150" />
                                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*" />
                                <DataGridTextColumn Header="Vehicle" Binding="{Binding VehicleNo}" Width="130" />
                                <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount}" Width="120" />
                                <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount}" Width="120" />
                                <DataGridTextColumn Header="Type" Binding="{Binding SaleType}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                        </ScrollViewer>
                    </Border>
                </DockPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}" VerticalAlignment="Top">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                        <TextBlock Text="Recent Purchase Orders" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Monitor procurement flow and status changes before distributing reports."
                                   Style="{StaticResource PageSubtitleText}" Margin="0" />
                    </StackPanel>
                    <Border Style="{StaticResource TableToolbarBorder}" DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Procurement register with supplier, status, and total visibility."
                                       Style="{StaticResource PageSubtitleText}"
                                       VerticalAlignment="Center"
                                       Margin="0" />
                            <Border Grid.Column="1" Style="{StaticResource TableCountBadge}" Margin="12,0,0,0">
                                <TextBlock Text="{Binding PurchaseRows.Count, StringFormat=Total: {0}}" Style="{StaticResource TableCountText}" />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource TableShellBorder}" Padding="8">
                        <ScrollViewer Style="{StaticResource TableViewportScrollViewer}">
                        <DataGrid ItemsSource="{Binding PurchaseRows}" AutoGenerateColumns="False" CanUserAddRows="False" MaxHeight="260" MinWidth="780">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="PO No" Binding="{Binding OrderNo}" Width="160" />
                                <DataGridTextColumn Header="Date" Binding="{Binding OrderDate}" Width="150" />
                                <DataGridTextColumn Header="Supplier" Binding="{Binding SupplierName}" Width="*" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                                <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                        </ScrollViewer>
                    </Border>
                </DockPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,16">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                            <TextBlock Text="Customer Ledger Summary" Style="{StaticResource CardTitleText}" />
                            <TextBlock Text="Highlight receivable exposure by customer." Style="{StaticResource PageSubtitleText}" Margin="0" />
                        </StackPanel>
                        <Border Style="{StaticResource TableToolbarBorder}" DockPanel.Dock="Top" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Receivable exposure by customer."
                                           Style="{StaticResource PageSubtitleText}"
                                           VerticalAlignment="Center"
                                           Margin="0" />
                                <Border Grid.Column="1" Style="{StaticResource TableCountBadge}" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding CustomerLedgerSummaryRows.Count, StringFormat=Total: {0}}" Style="{StaticResource TableCountText}" />
                                </Border>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource TableShellBorder}" Padding="8">
                            <ScrollViewer Style="{StaticResource TableViewportScrollViewer}">
                            <DataGrid ItemsSource="{Binding CustomerLedgerSummaryRows}" AutoGenerateColumns="False" CanUserAddRows="False" MaxHeight="240" MinWidth="520">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Code" Binding="{Binding PartyCode}" Width="120" />
                                    <DataGridTextColumn Header="Customer" Binding="{Binding PartyName}" Width="*" />
                                    <DataGridTextColumn Header="Balance" Binding="{Binding Balance}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                            </ScrollViewer>
                        </Border>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                            <TextBlock Text="Supplier Ledger Summary" Style="{StaticResource CardTitleText}" />
                            <TextBlock Text="Highlight payable exposure by supplier." Style="{StaticResource PageSubtitleText}" Margin="0" />
                        </StackPanel>
                        <Border Style="{StaticResource TableToolbarBorder}" DockPanel.Dock="Top" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Payable exposure by supplier."
                                           Style="{StaticResource PageSubtitleText}"
                                           VerticalAlignment="Center"
                                           Margin="0" />
                                <Border Grid.Column="1" Style="{StaticResource TableCountBadge}" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding SupplierLedgerSummaryRows.Count, StringFormat=Total: {0}}" Style="{StaticResource TableCountText}" />
                                </Border>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource TableShellBorder}" Padding="8">
                            <ScrollViewer Style="{StaticResource TableViewportScrollViewer}">
                            <DataGrid ItemsSource="{Binding SupplierLedgerSummaryRows}" AutoGenerateColumns="False" CanUserAddRows="False" MaxHeight="240" MinWidth="520">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Code" Binding="{Binding PartyCode}" Width="120" />
                                    <DataGridTextColumn Header="Supplier" Binding="{Binding PartyName}" Width="*" />
                                    <DataGridTextColumn Header="Balance" Binding="{Binding Balance}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                            </ScrollViewer>
                        </Border>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
