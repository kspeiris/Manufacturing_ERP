<Window x:Class="ManufacturingERP.Desktop.Views.SupplierDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Supplier"
        Height="500"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppCanvasBrush}">
    <Grid Margin="18">
        <Border Style="{StaticResource SectionCard}" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Supplier Profile" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Maintain supplier master data with a clearer contact and address form."
                               Style="{StaticResource PageSubtitleText}" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Supplier Code" Style="{StaticResource FormLabel}" />
                    <TextBox Text="{Binding SupplierCode}" materialDesign:HintAssist.Hint="Supplier code" />
                    <TextBlock Text="Name" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                    <TextBox Text="{Binding Name}" materialDesign:HintAssist.Hint="Supplier name" />
                    <TextBlock Text="Phone" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                    <TextBox Text="{Binding ContactNumber}" materialDesign:HintAssist.Hint="Primary phone number" />
                    <TextBlock Text="Address" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                    <TextBox Text="{Binding Address}" Height="110" AcceptsReturn="True" TextWrapping="Wrap" materialDesign:HintAssist.Hint="Registered address" />
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="Save" Width="110" Margin="0,0,8,0" Click="Save_Click" />
                    <Button Content="Cancel" Width="110" Click="Cancel_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
