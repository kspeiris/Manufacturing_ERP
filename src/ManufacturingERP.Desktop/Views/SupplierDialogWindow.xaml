<Window x:Class="ManufacturingERP.Desktop.Views.SupplierDialogWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Supplier" Height="520" Width="520" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="{StaticResource AppBackgroundBrush}">
    <Border Margin="20" Style="{StaticResource ViewRootCard}">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Supplier" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Capture supplier identity and contact information in a cleaner single-column form." Style="{StaticResource PageSubtitleText}" Margin="0,0,0,20" />
                    <TextBlock Text="Supplier Code" Style="{StaticResource FormLabel}" />
                    <TextBox Text="{Binding SupplierCode}" />
                    <TextBlock Text="Name" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Text="{Binding Name}" />
                    <TextBlock Text="Phone" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Text="{Binding ContactNumber}" />
                    <TextBlock Text="Address" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Height="110" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Address}" />
                </StackPanel>
            </ScrollViewer>
            <WrapPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Save" Width="110" Style="{StaticResource PrimaryActionButton}" Click="Save_Click" />
                <Button Content="Cancel" Width="110" Style="{StaticResource SecondaryActionButton}" Margin="0" Click="Cancel_Click" />
            </WrapPanel>
        </Grid>
    </Border>
</Window>
