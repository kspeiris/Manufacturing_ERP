<UserControl x:Class="ManufacturingERP.Desktop.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,8">
            <Border Style="{StaticResource HeroCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="Customers / Shops" Style="{StaticResource HeroTitleText}" />
                        <TextBlock Text="Commercial directory" Style="{StaticResource HeroEyebrowText}" Margin="0,6,0,0" />
                        <TextBlock Text="Maintain customer identity, route assignment, contact data, and receivable visibility in one place."
                                   Style="{StaticResource HeroBodyText}" Margin="0,12,0,0" MaxWidth="700" />
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <WrapPanel HorizontalAlignment="Right">
                            <Button Content="New" Command="{Binding AddCommand}" Style="{StaticResource PageActionButton}" />
                            <Button Content="Edit" Command="{Binding EditCommand}" Style="{StaticResource PageActionButton}" />
                            <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource PageDangerButton}" />
                            <Button Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource PageActionButton}" Margin="0" />
                        </WrapPanel>

                        <Border Grid.Row="2" Background="{StaticResource AppDarkPanelBrush}" BorderBrush="{StaticResource AppPrimaryBrush}" BorderThickness="1" CornerRadius="18" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Selected Shop" Foreground="{StaticResource AppPrimaryLightBrush}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedCustomer.ShopName, TargetNullValue=No customer selected}" Foreground="White" FontSize="22" FontWeight="SemiBold" Margin="0,10,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedCustomer.Route, StringFormat=Route: {0}, TargetNullValue=Pick a row in the directory to inspect customer details.}" Foreground="{StaticResource AppMutedLightBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AppPrimaryLightBrush}" Margin="0,10,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,16">
                    <StackPanel>
                        <TextBlock Text="Customers Loaded" Style="{StaticResource InlineStatLabel}" />
                        <TextBlock Text="{Binding Customers.Count}" Style="{StaticResource InlineStatValue}" />
                        <TextBlock Text="Current visible customer records." Style="{StaticResource PageSubtitleText}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource SectionCard}" Margin="0,0,16,16">
                    <StackPanel>
                        <TextBlock Text="Search Scope" Style="{StaticResource InlineStatLabel}" />
                        <TextBlock Text="Code, shop, owner, route, or phone" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource SectionCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Selected Shop" Style="{StaticResource InlineStatLabel}" />
                        <TextBlock Text="{Binding SelectedCustomer.ShopName, TargetNullValue=No customer selected}" Style="{StaticResource InlineStatValue}" />
                        <TextBlock Text="{Binding SelectedCustomer.Route, StringFormat=Route: {0}, TargetNullValue=Choose a row from the directory}" Style="{StaticResource PageSubtitleText}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.15*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,16">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Customer Directory" Style="{StaticResource CardTitleText}" />
                                <TextBlock Text="Use the directory to manage outlet details, routes, and outstanding balances." Style="{StaticResource PageSubtitleText}" Margin="0" />
                            </StackPanel>
                            <Border Grid.Column="1" Style="{StaticResource TableCountBadge}">
                                <TextBlock Text="{Binding Customers.Count, StringFormat=Total: {0}}" Style="{StaticResource TableCountText}" />
                            </Border>
                        </Grid>
                        <Border DockPanel.Dock="Top" Style="{StaticResource TableToolbarBorder}" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Search by code, shop, owner, route, or phone" />
                                <Button Grid.Column="1"
                                        Content="Refresh"
                                        Command="{Binding LoadCommand}"
                                        Style="{StaticResource PageActionButton}"
                                        Margin="12,0,0,0" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource TableShellBorder}" Padding="8">
                            <ScrollViewer Style="{StaticResource TableViewportScrollViewer}">
                            <DataGrid ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" AutoGenerateColumns="False" CanUserAddRows="False" MaxHeight="460" MinWidth="980">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Code" Binding="{Binding CustomerCode}" Width="120" />
                                    <DataGridTextColumn Header="Shop" Binding="{Binding ShopName}" Width="220" />
                                    <DataGridTextColumn Header="Owner" Binding="{Binding OwnerName}" Width="180" />
                                    <DataGridTextColumn Header="Route" Binding="{Binding Route}" Width="120" />
                                    <DataGridTextColumn Header="Phone" Binding="{Binding ContactNumber}" Width="140" />
                                    <DataGridTextColumn Header="Outstanding" Binding="{Binding OutstandingBalance, StringFormat=N2}" Width="140" />
                                    <DataGridTemplateColumn Header="Status" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border x:Name="StatusBadge" Background="#FEE2E2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="999" Padding="10,4" HorizontalAlignment="Left">
                                                    <TextBlock x:Name="StatusText" Text="Inactive" Foreground="{StaticResource AppDangerBrush}" FontWeight="SemiBold" />
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter TargetName="StatusBadge" Property="Background" Value="#DCFCE7" />
                                                        <Setter TargetName="StatusBadge" Property="BorderBrush" Value="#BBF7D0" />
                                                        <Setter TargetName="StatusText" Property="Text" Value="Active" />
                                                        <Setter TargetName="StatusText" Property="Foreground" Value="{StaticResource AppSuccessBrush}" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Actions" Width="132">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource TableActionIconButton}" ToolTip="View" Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                        <materialDesign:PackIcon Kind="EyeOutline" Width="18" Height="18" Foreground="{StaticResource AppPrimaryBrush}" />
                                                    </Button>
                                                    <Button Style="{StaticResource TableActionIconButton}" ToolTip="Edit" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                        <materialDesign:PackIcon Kind="PencilOutline" Width="18" Height="18" Foreground="{StaticResource AppWarningBrush}" />
                                                    </Button>
                                                    <Button Style="{StaticResource TableActionIconButton}" ToolTip="Delete" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="0">
                                                        <materialDesign:PackIcon Kind="TrashCanOutline" Width="18" Height="18" Foreground="{StaticResource AppDangerBrush}" />
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            </ScrollViewer>
                        </Border>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Customer Details" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Review the currently selected customer before editing or deleting." Style="{StaticResource PageSubtitleText}" Margin="0,-2,0,18" />

                        <Border Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Shop / Owner" Style="{StaticResource InlineStatLabel}" />
                                <TextBlock Text="{Binding SelectedCustomer.ShopName, TargetNullValue=No shop selected}" Style="{StaticResource InlineStatValue}" />
                                <TextBlock Text="{Binding SelectedCustomer.OwnerName, StringFormat=Owner: {0}, TargetNullValue=Owner: -}" Style="{StaticResource PageSubtitleText}" />
                            </StackPanel>
                        </Border>

                        <Border Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Route / Phone" Style="{StaticResource InlineStatLabel}" />
                                <TextBlock Text="{Binding SelectedCustomer.Route, TargetNullValue=-}" Style="{StaticResource InlineStatValue}" />
                                <TextBlock Text="{Binding SelectedCustomer.ContactNumber, StringFormat=Phone: {0}, TargetNullValue=Phone: -}" Style="{StaticResource PageSubtitleText}" />
                            </StackPanel>
                        </Border>

                        <Border Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="16" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Financial Snapshot" Style="{StaticResource InlineStatLabel}" />
                                <TextBlock Text="{Binding SelectedCustomer.OutstandingBalance, StringFormat=Outstanding: {0:N2}, TargetNullValue=Outstanding: -}" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding SelectedCustomer.CreditLimit, StringFormat=Credit Limit: {0:N2}, TargetNullValue=Credit Limit: -}" Style="{StaticResource PageSubtitleText}" />
                                <TextBlock Text="{Binding SelectedCustomer.IsActive, StringFormat=Active: {0}, TargetNullValue=Active: -}" Style="{StaticResource PageSubtitleText}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
