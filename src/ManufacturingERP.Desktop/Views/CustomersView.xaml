<UserControl x:Class="ManufacturingERP.Desktop.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Border Style="{StaticResource ViewRootCard}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <DockPanel LastChildFill="False" Margin="0,0,0,14">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Customers / Shops" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Manage outlets, owners, routes, and credit exposure from one searchable list." Style="{StaticResource PageSubtitleText}" />
                </StackPanel>
                <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Content="New" Command="{Binding AddCommand}" Style="{StaticResource PrimaryActionButton}" />
                    <Button Content="Edit" Command="{Binding EditCommand}" Style="{StaticResource SecondaryActionButton}" />
                    <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource DangerActionButton}" />
                    <Button Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryActionButton}" Margin="0" />
                </WrapPanel>
            </DockPanel>
            <StackPanel Grid.Row="1" Margin="0,0,0,14">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search by code, shop, owner, route, or phone" />
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusMessageText}" />
            </StackPanel>
            <DataGrid Grid.Row="2" ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding CustomerCode}" Width="120" />
                    <DataGridTextColumn Header="Shop" Binding="{Binding ShopName}" Width="*" />
                    <DataGridTextColumn Header="Owner" Binding="{Binding OwnerName}" Width="180" />
                    <DataGridTextColumn Header="Route" Binding="{Binding Route}" Width="120" />
                    <DataGridTextColumn Header="Phone" Binding="{Binding ContactNumber}" Width="140" />
                    <DataGridTextColumn Header="Outstanding" Binding="{Binding OutstandingBalance}" Width="140" />
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
