<UserControl x:Class="ManufacturingERP.Desktop.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Border Background="White" CornerRadius="18" Padding="18">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                <DockPanel>
                    <TextBlock Text="Customers / Shops" FontSize="28" FontWeight="Bold" />
                    <WrapPanel HorizontalAlignment="Right">
                        <Button Content="New" Command="{Binding AddCommand}" Margin="0,0,8,0" />
                        <Button Content="Edit" Command="{Binding EditCommand}" Margin="0,0,8,0" />
                        <Button Content="Delete" Command="{Binding DeleteCommand}" Margin="0,0,8,0" />
                        <Button Content="Refresh" Command="{Binding LoadCommand}" />
                    </WrapPanel>
                </DockPanel>
                <TextBox Margin="0,12,0,0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search by code, shop, owner, route, or phone" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#2563EB" Margin="0,8,0,0" />
            </StackPanel>
            <DataGrid ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" RowHeight="34">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding CustomerCode}" Width="120" />
                    <DataGridTextColumn Header="Shop" Binding="{Binding ShopName}" Width="*" />
                    <DataGridTextColumn Header="Owner" Binding="{Binding OwnerName}" Width="180" />
                    <DataGridTextColumn Header="Route" Binding="{Binding Route}" Width="120" />
                    <DataGridTextColumn Header="Phone" Binding="{Binding ContactNumber}" Width="140" />
                    <DataGridTextColumn Header="Outstanding" Binding="{Binding OutstandingBalance}" Width="140" />
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
