<UserControl x:Class="ManufacturingERP.Desktop.Views.CollectionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Collections" Style="{StaticResource PageTitleText}" />
            <TextBlock Text="Record incoming customer payments with visible outstanding balances and a cleaner collections ledger."
                       Style="{StaticResource PageSubtitleText}"
                       Margin="0,0,0,18" />

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource InlineStatCard}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Open Collections" Style="{StaticResource InlineStatLabel}" />
                        <TextBlock Text="{Binding Collections.Count}" Style="{StaticResource InlineStatValue}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource UtilityPanel}">
                    <StackPanel>
                        <TextBlock Text="Selected Customer Position" Style="{StaticResource InlineStatLabel}" />
                        <TextBlock Text="{Binding SelectedCustomerOutstanding, StringFormat=Outstanding: {0:N2}}" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1.95*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Collection Entry" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Capture the payment amount, reference, and notes against the selected customer."
                                   Style="{StaticResource PageSubtitleText}"
                                   Margin="0,0,0,16" />
                        <TextBlock Text="Customer" Style="{StaticResource FormLabel}" />
                        <ComboBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" DisplayMemberPath="ShopName" />
                        <TextBlock Text="Amount" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding Amount}" />
                        <TextBlock Text="Reference No" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding ReferenceNo}" />
                        <TextBlock Text="Notes" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding Notes}" Height="90" AcceptsReturn="True" TextWrapping="Wrap" />
                        <WrapPanel Margin="0,16,0,0">
                            <Button Content="Save Collection" Command="{Binding SaveCollectionCommand}" Margin="0,0,8,0" />
                            <Button Content="Refresh" Command="{Binding LoadCommand}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <TextBlock Text="Recent Collections" Style="{StaticResource CardTitleText}" />
                            <TextBlock Text="Review the latest cash receipts and customer references."
                                       Style="{StaticResource PageSubtitleText}"
                                       Margin="0" />
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding Collections}" AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding CollectionDate}" Width="160" />
                                <DataGridTextColumn Header="Customer" Binding="{Binding Customer.ShopName}" Width="*" />
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="120" />
                                <DataGridTextColumn Header="Reference" Binding="{Binding ReferenceNo}" Width="140" />
                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="220" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
