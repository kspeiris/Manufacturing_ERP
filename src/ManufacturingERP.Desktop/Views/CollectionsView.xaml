<UserControl x:Class="ManufacturingERP.Desktop.Views.CollectionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Collections" Style="{StaticResource PageTitleText}" />
            <TextBlock Text="Capture customer receipts with the current outstanding balance visible while you work." Style="{StaticResource PageSubtitleText}" Margin="0,0,0,18" />
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="1.1*"/><ColumnDefinition Width="1.9*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                    <StackPanel>
                <TextBlock Text="Customer Collection Entry" Style="{StaticResource CardTitleText}" />
                <TextBlock Text="Customer" Style="{StaticResource FormLabel}" />
                <ComboBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" DisplayMemberPath="ShopName" />
                <TextBlock Text="{Binding SelectedCustomerOutstanding, StringFormat=Outstanding: {0:N2}}" Margin="0,8,0,0" Style="{StaticResource CaptionText}" />
                <TextBlock Text="Amount" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                <TextBox Text="{Binding Amount}" />
                <TextBlock Text="Reference No" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                <TextBox Text="{Binding ReferenceNo}" />
                <TextBlock Text="Notes" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                <TextBox Text="{Binding Notes}" Height="90" AcceptsReturn="True" TextWrapping="Wrap" />
                <WrapPanel Margin="0,16,0,0">
                    <Button Content="Save Collection" Command="{Binding SaveCollectionCommand}" Style="{StaticResource PrimaryActionButton}" />
                    <Button Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryActionButton}" Margin="0" />
                </WrapPanel>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusMessageText}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                    <DockPanel>
                        <TextBlock Text="Recent Collections" Style="{StaticResource CardTitleText}" DockPanel.Dock="Top" />
                        <DataGrid ItemsSource="{Binding Collections}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding CollectionDate}" Width="160" />
                        <DataGridTextColumn Header="Customer" Binding="{Binding Customer.ShopName}" Width="*" />
                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="120" />
                        <DataGridTextColumn Header="Reference" Binding="{Binding ReferenceNo}" Width="140" />
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="220" />
                    </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
