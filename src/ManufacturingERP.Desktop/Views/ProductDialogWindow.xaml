<Window x:Class="ManufacturingERP.Desktop.Views.ProductDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Product"
        Height="560"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppCanvasBrush}">
    <Grid Margin="18">
        <Border Style="{StaticResource SectionCard}" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Product Profile" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Configure catalog identity, unit economics, and inventory behavior."
                               Style="{StaticResource PageSubtitleText}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Code" Style="{StaticResource FormLabel}" />
                        <TextBox Text="{Binding Code}" materialDesign:HintAssist.Hint="Product code" />
                        <TextBlock Text="Name" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding Name}" materialDesign:HintAssist.Hint="Product name" />
                        <TextBlock Text="Unit" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding Unit}" materialDesign:HintAssist.Hint="Inventory unit" />
                        <TextBlock Text="Cost Price" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding CostPrice}" materialDesign:HintAssist.Hint="Standard cost" />
                        <TextBlock Text="Selling Price" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding SellingPrice}" materialDesign:HintAssist.Hint="Selling price" />
                        <CheckBox Content="Track Batch" IsChecked="{Binding TrackBatch}" Margin="0,16,0,0" />
                        <CheckBox Content="Active" IsChecked="{Binding IsActive}" Margin="0,10,0,0" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="Save" Width="110" Margin="0,0,8,0" Click="Save_Click" />
                    <Button Content="Cancel" Width="110" Click="Cancel_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
