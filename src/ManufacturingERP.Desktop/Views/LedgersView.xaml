<UserControl x:Class="ManufacturingERP.Desktop.Views.LedgersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Customer &amp; Supplier Ledgers" FontSize="30" FontWeight="Bold" Margin="0,0,0,18" />
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <TextBlock Text="Customer Ledger" Style="{StaticResource CardTitleText}" />
                            <WrapPanel>
                                <ComboBox Width="240" ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" DisplayMemberPath="ShopName" Margin="0,0,8,0" />
                                <Button Content="Load" Command="{Binding LoadCustomerLedgerCommand}" />
                            </WrapPanel>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding CustomerRows}" AutoGenerateColumns="False" CanUserAddRows="False" Height="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding EntryDate}" Width="140" />
                                <DataGridTextColumn Header="Type" Binding="{Binding EntryType}" Width="120" />
                                <DataGridTextColumn Header="Ref" Binding="{Binding ReferenceNo}" Width="140" />
                                <DataGridTextColumn Header="Debit" Binding="{Binding Debit}" Width="100" />
                                <DataGridTextColumn Header="Credit" Binding="{Binding Credit}" Width="100" />
                                <DataGridTextColumn Header="Balance" Binding="{Binding RunningBalance}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <TextBlock Text="Supplier Ledger" Style="{StaticResource CardTitleText}" />
                            <WrapPanel>
                                <ComboBox Width="240" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="Name" Margin="0,0,8,0" />
                                <Button Content="Load" Command="{Binding LoadSupplierLedgerCommand}" />
                            </WrapPanel>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding SupplierRows}" AutoGenerateColumns="False" CanUserAddRows="False" Height="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding EntryDate}" Width="140" />
                                <DataGridTextColumn Header="Type" Binding="{Binding EntryType}" Width="120" />
                                <DataGridTextColumn Header="Ref" Binding="{Binding ReferenceNo}" Width="140" />
                                <DataGridTextColumn Header="Debit" Binding="{Binding Debit}" Width="100" />
                                <DataGridTextColumn Header="Credit" Binding="{Binding Credit}" Width="100" />
                                <DataGridTextColumn Header="Balance" Binding="{Binding RunningBalance}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
