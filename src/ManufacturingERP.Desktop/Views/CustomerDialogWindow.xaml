<Window x:Class="ManufacturingERP.Desktop.Views.CustomerDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer" Height="620" Width="560" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}">
    <Border Margin="20" Style="{StaticResource ViewRootCard}">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Customer" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Maintain the outlet profile, owner details, route, credit, and address in one form." Style="{StaticResource PageSubtitleText}" Margin="0,0,0,20" />
                    <TextBlock Text="Customer Code" Style="{StaticResource FormLabel}" />
                    <TextBox Text="{Binding CustomerCode}" />
                    <TextBlock Text="Shop Name" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Text="{Binding ShopName}" />
                    <TextBlock Text="Owner" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Text="{Binding OwnerName}" />
                    <TextBlock Text="Route" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Text="{Binding Route}" />
                    <TextBlock Text="Phone" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Text="{Binding ContactNumber}" />
                    <TextBlock Text="Credit Limit" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Text="{Binding CreditLimit}" />
                    <TextBlock Text="Address" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Height="96" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding Address}" />
                    <CheckBox Content="Active" IsChecked="{Binding IsActive}" />
                </StackPanel>
            </ScrollViewer>
            <WrapPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Save" Width="110" Style="{StaticResource PrimaryActionButton}" Click="Save_Click" />
                <Button Content="Cancel" Width="110" Style="{StaticResource SecondaryActionButton}" Margin="0" Click="Cancel_Click" />
            </WrapPanel>
        </Grid>
    </Border>
</Window>
