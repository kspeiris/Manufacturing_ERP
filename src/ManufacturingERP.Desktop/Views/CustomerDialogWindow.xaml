<Window x:Class="ManufacturingERP.Desktop.Views.CustomerDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Customer"
        Height="620"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EAF1FA">
    <Grid Margin="18">
        <Border Style="{StaticResource SectionCard}" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Customer Profile" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Maintain outlet identity, credit settings, and route details from one clean dialog."
                               Style="{StaticResource PageSubtitleText}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Customer Code" Style="{StaticResource FormLabel}" />
                        <TextBox Text="{Binding CustomerCode}" materialDesign:HintAssist.Hint="Unique customer code" />
                        <TextBlock Text="Shop Name" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding ShopName}" materialDesign:HintAssist.Hint="Registered shop name" />
                        <TextBlock Text="Owner" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding OwnerName}" materialDesign:HintAssist.Hint="Owner or contact person" />
                        <TextBlock Text="Route" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding Route}" materialDesign:HintAssist.Hint="Assigned route" />
                        <TextBlock Text="Phone" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding ContactNumber}" materialDesign:HintAssist.Hint="Primary phone number" />
                        <TextBlock Text="Credit Limit" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding CreditLimit}" materialDesign:HintAssist.Hint="Approved credit limit" />
                        <TextBlock Text="Address" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding Address}" Height="90" TextWrapping="Wrap" AcceptsReturn="True" materialDesign:HintAssist.Hint="Billing or delivery address" />
                        <CheckBox Content="Active" IsChecked="{Binding IsActive}" Margin="0,14,0,0" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="Save" Width="110" Margin="0,0,8,0" Click="Save_Click" />
                    <Button Content="Cancel" Width="110" Click="Cancel_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
