<UserControl x:Class="ManufacturingERP.Desktop.Views.Phase3ProcurementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Supplier Invoices &amp; Purchase Returns" FontSize="30" FontWeight="Bold" Margin="0,0,0,18" />

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Supplier Invoice Entry" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Supplier" Style="{StaticResource FormLabel}" />
                        <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="Name" />
                        <TextBlock Text="Reference PO" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding ReferencePoNo}" />
                        <TextBlock Text="Reference GRN" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding ReferenceGrnNo}" />
                        <TextBlock Text="Latest GRNs appear automatically when you pick a supplier." Foreground="#64748B" TextWrapping="Wrap" Margin="0,6,0,0" />
                        <TextBlock Text="Invoice Amount" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding InvoiceAmount}" />
                        <TextBlock Text="Paid Amount" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding PaidAmount}" />
                        <Button Content="Save Supplier Invoice" Command="{Binding SaveSupplierInvoiceCommand}" Margin="0,16,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Purchase Return Entry" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Warehouse" Style="{StaticResource FormLabel}" />
                        <ComboBox ItemsSource="{Binding Warehouses}" SelectedItem="{Binding SelectedWarehouse}" DisplayMemberPath="Name" />
                        <TextBlock Text="Reference Supplier Invoice" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding ReferenceInvoiceNo}" />
                        <TextBlock Text="Reason" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding Reason}" />
                        <WrapPanel Margin="0,12,0,8">
                            <Button Content="Add Return Line" Command="{Binding AddReturnLineCommand}" Margin="0,0,8,0" />
                            <Button Content="Save Purchase Return" Command="{Binding SavePurchaseReturnCommand}" />
                        </WrapPanel>
                        <DataGrid ItemsSource="{Binding ReturnLines}" AutoGenerateColumns="False" CanUserAddRows="False" Height="220">
                            <DataGrid.Columns>
                                <DataGridComboBoxColumn Header="Product" Width="*" SelectedItemBinding="{Binding Product}" DisplayMemberPath="Name"
                                                        SelectedValuePath="."
                                                        ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="110" />
                                <DataGridTextColumn Header="Unit Cost" Binding="{Binding UnitCost}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="{Binding StatusMessage}" Foreground="#2563EB" Margin="0,0,0,12" />

            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                    <DockPanel>
                        <TextBlock Text="Supplier Invoices" Style="{StaticResource CardTitleText}" DockPanel.Dock="Top" />
                        <DataGrid ItemsSource="{Binding SupplierInvoices}" AutoGenerateColumns="False" CanUserAddRows="False" Height="260">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Invoice No" Binding="{Binding InvoiceNo}" Width="160" />
                                <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDate}" Width="140" />
                                <DataGridTextColumn Header="Supplier" Binding="{Binding Supplier.Name}" Width="*" />
                                <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount}" Width="120" />
                                <DataGridTextColumn Header="Balance" Binding="{Binding BalanceAmount}" Width="120" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                    <DockPanel>
                        <TextBlock Text="Purchase Returns" Style="{StaticResource CardTitleText}" DockPanel.Dock="Top" />
                        <DataGrid ItemsSource="{Binding PurchaseReturns}" AutoGenerateColumns="False" CanUserAddRows="False" Height="260">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Return No" Binding="{Binding ReturnNo}" Width="160" />
                                <DataGridTextColumn Header="Date" Binding="{Binding ReturnDate}" Width="140" />
                                <DataGridTextColumn Header="Supplier" Binding="{Binding Supplier.Name}" Width="*" />
                                <DataGridTextColumn Header="Warehouse" Binding="{Binding Warehouse.Name}" Width="160" />
                                <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
