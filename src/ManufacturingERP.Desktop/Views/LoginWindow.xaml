<Window x:Class="ManufacturingERP.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Manufacturing ERP - Login"
        Height="520"
        Width="880"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#DCE7F5">
    <Grid Margin="18">
        <Border CornerRadius="30" Background="#0F172A" BorderBrush="#1E3A8A" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <Grid Margin="34">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel VerticalAlignment="Center" Margin="0,0,26,0">
                        <TextBlock Text="Manufacturing ERP" Style="{StaticResource HeroTitleText}" />
                        <TextBlock Text="Operations suite for manufacturing, warehousing, van sales, collections, and finance."
                                   Style="{StaticResource HeroBodyText}"
                                   Margin="0,16,0,0" />

                        <UniformGrid Columns="2" Margin="0,28,0,0">
                            <Border Background="#172554" BorderBrush="#2563EB" BorderThickness="1" CornerRadius="18" Padding="18" Margin="0,0,14,14">
                                <StackPanel>
                                    <TextBlock Text="Unified Control" Foreground="#93C5FD" FontWeight="SemiBold" />
                                    <TextBlock Text="Sales, supply chain, and finance in one desktop workflow."
                                               Foreground="White"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Background="#172554" BorderBrush="#2563EB" BorderThickness="1" CornerRadius="18" Padding="18" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Traceable Operations" Foreground="#93C5FD" FontWeight="SemiBold" />
                                    <TextBlock Text="Auditable transactions across warehouse, production, and collections."
                                               Foreground="White"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>

                    <TextBlock Grid.Row="1"
                               Text="Professional workspace for administrators, finance, warehouse, and sales teams."
                               Foreground="#8FA4C8"
                               FontSize="13"
                               TextWrapping="Wrap" />
                </Grid>

                <Grid Grid.Column="1" Margin="22">
                    <Border Style="{StaticResource SectionCard}" VerticalAlignment="Center" Padding="28">
                        <StackPanel>
                            <TextBlock Text="Sign In" Style="{StaticResource PageTitleText}" />
                            <TextBlock Text="Use your ERP credentials to access the workspace."
                                       Style="{StaticResource PageSubtitleText}"
                                       Margin="0,4,0,20" />
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Username"
                                     Margin="0,0,0,14" />
                            <PasswordBox x:Name="PasswordBox"
                                         PasswordChanged="PasswordBox_OnPasswordChanged"
                                         Margin="0,0,0,14" />
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#DC2626"
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap" />
                            <Button Content="Login"
                                    Click="LoginButton_OnClick"
                                    Height="44" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
