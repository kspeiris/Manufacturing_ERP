<Window x:Class="ManufacturingERP.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Manufacturing ERP - Login" Height="420" Width="700" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Background="#F5F7FB">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.25*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Border Background="#1E2A78" CornerRadius="0,24,24,0" Padding="36">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Manufacturing ERP" FontSize="34" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="Factory, warehouse, van sales, collections and reporting in one desktop system." 
                           Margin="0,14,0,0" Foreground="#DDE4FF" TextWrapping="Wrap" FontSize="16" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Margin="28" Padding="28" Background="White" CornerRadius="20" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Sign in" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,18" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Username" Margin="0,0,0,12" />
                <PasswordBox x:Name="PasswordBox" PasswordChanged="PasswordBox_OnPasswordChanged" Margin="0,0,0,12" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Crimson" Margin="0,0,0,10" />
                <Button Content="Login" Click="LoginButton_OnClick" Style="{StaticResource MaterialDesignRaisedButton}" Height="42" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
