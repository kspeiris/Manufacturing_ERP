<UserControl x:Class="ManufacturingERP.Desktop.Views.PosSalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource SectionCard}" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="POS Checkout" Style="{StaticResource PageTitleText}" />
                        <TextBlock Text="Fast cashier flow with keyboard-first actions and live totals." Style="{StaticResource PageSubtitleText}" Margin="0,6,0,0" />
                        <WrapPanel Margin="0,18,0,0">
                            <Button Content="Add Line" Command="{Binding AddLineCommand}" Style="{StaticResource SecondaryActionButton}" />
                            <Button Content="Checkout Cash Sale" Command="{Binding CheckoutCommand}" Style="{StaticResource PrimaryActionButton}" Margin="0" />
                        </WrapPanel>
                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusMessageText}" />
                    </StackPanel>

                    <Border Grid.Column="1" Background="#EFF6FF" CornerRadius="18" Padding="16" Margin="16,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Items" Style="{StaticResource FormLabel}" Margin="0" />
                            <TextBlock Text="{Binding TotalLines}" Style="{StaticResource MetricValueText}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#ECFDF5" CornerRadius="18" Padding="16" Margin="16,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Grand Total" Style="{StaticResource FormLabel}" Margin="0" />
                            <TextBlock Text="{Binding GrandTotal, StringFormat=N2}" Style="{StaticResource MetricValueText}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="#FFF7ED" CornerRadius="18" Padding="16" Margin="16,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Shortcuts" Style="{StaticResource FormLabel}" Margin="0" />
                            <TextBlock Text="Ctrl+3 POS" Style="{StaticResource CaptionText}" />
                            <TextBlock Text="Ctrl+1 Dashboard" Style="{StaticResource CaptionText}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1.95*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Order Details" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Customer" Style="{StaticResource FormLabel}" />
                        <ComboBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" DisplayMemberPath="ShopName" />
                        <TextBlock Text="Vehicle" Style="{StaticResource FormLabel}" />
                        <ComboBox ItemsSource="{Binding Vehicles}" SelectedItem="{Binding SelectedVehicle}" DisplayMemberPath="VehicleNumber" />

                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="Validation Tips" Style="{StaticResource FormLabel}" Margin="0" />
                                <TextBlock Text="Select customer and vehicle before checkout." Style="{StaticResource CaptionText}" />
                                <TextBlock Text="Keep quantities above zero to include a line." Style="{StaticResource CaptionText}" Margin="0,4,0,0" />
                                <TextBlock Text="Use Add Line to continue scanning items." Style="{StaticResource CaptionText}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ProgressBar Grid.Row="0" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <DockPanel Grid.Row="1">
                            <TextBlock Text="POS Items" Style="{StaticResource CardTitleText}" DockPanel.Dock="Top" />
                            <DataGrid ItemsSource="{Binding Lines}">
                                <DataGrid.Columns>
                                    <DataGridComboBoxColumn Header="Product" Width="*" SelectedItemBinding="{Binding Product}" DisplayMemberPath="Name" SelectedValuePath="."
                                                            ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="120" />
                                    <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice}" Width="140" />
                                    <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal, StringFormat=N2}" Width="140" IsReadOnly="True" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
