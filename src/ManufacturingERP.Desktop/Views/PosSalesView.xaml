<UserControl x:Class="ManufacturingERP.Desktop.Views.PosSalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <DockPanel Margin="0,0,0,14">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="POS Sales" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Process fast cash sales with clear checkout context, item totals, and operator guidance."
                               Style="{StaticResource PageSubtitleText}" />
                </StackPanel>
            </DockPanel>

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource InlineStatCard}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Items in Bill" Style="{StaticResource InlineStatLabel}" />
                        <TextBlock Text="{Binding TotalLines}" Style="{StaticResource InlineStatValue}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource InlineStatCard}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Bill Total" Style="{StaticResource InlineStatLabel}" />
                        <TextBlock Text="{Binding GrandTotal, StringFormat=N2}" Style="{StaticResource InlineStatValue}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource UtilityPanel}">
                    <StackPanel>
                        <TextBlock Text="Checkout Status" Style="{StaticResource InlineStatLabel}" />
                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1.95*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Checkout Desk" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Select the receiving customer and route vehicle before completing the sale."
                                   Style="{StaticResource PageSubtitleText}"
                                   Margin="0,0,0,16" />
                        <TextBlock Text="Customer" Style="{StaticResource FormLabel}" />
                        <ComboBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" DisplayMemberPath="ShopName" />
                        <TextBlock Text="Vehicle" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <ComboBox ItemsSource="{Binding Vehicles}" SelectedItem="{Binding SelectedVehicle}" DisplayMemberPath="VehicleNumber" />
                        <TextBlock Text="Use the action buttons in the items panel to add lines and complete checkout."
                                   Style="{StaticResource PageSubtitleText}"
                                   Margin="0,16,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SectionCard}" VerticalAlignment="Top">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <WrapPanel DockPanel.Dock="Right" Margin="12,0,0,0">
                                <Button Content="Add Line" Command="{Binding AddLineCommand}" Margin="0,0,8,0" />
                                <Button Content="Checkout Cash Sale" Command="{Binding CheckoutCommand}" />
                            </WrapPanel>
                            <StackPanel>
                                <TextBlock Text="POS Items" Style="{StaticResource CardTitleText}" />
                                <TextBlock Text="Build the current sale and confirm line totals before checkout."
                                           Style="{StaticResource PageSubtitleText}"
                                           Margin="0" />
                            </StackPanel>
                        </DockPanel>
                        <DataGrid ItemsSource="{Binding Lines}" AutoGenerateColumns="False" CanUserAddRows="False" MaxHeight="260">
                            <DataGrid.Columns>
                                <DataGridComboBoxColumn Header="Product" Width="*" SelectedItemBinding="{Binding Product}" DisplayMemberPath="Name" SelectedValuePath="."
                                    ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="120" />
                                <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice}" Width="140" />
                                <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal}" Width="140" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
