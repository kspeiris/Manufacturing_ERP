<UserControl x:Class="ManufacturingERP.Desktop.Views.PosSalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="POS Sales" Style="{StaticResource PageTitleText}" />
            <TextBlock Text="Build a quick cash sale while keeping totals and line items visible in the same workspace." Style="{StaticResource PageSubtitleText}" Margin="0,0,0,18" />
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="1.1*"/><ColumnDefinition Width="1.9*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                    <StackPanel>
                <TextBlock Text="POS Checkout" Style="{StaticResource CardTitleText}" />
                <TextBlock Text="Customer" Style="{StaticResource FormLabel}" />
                <ComboBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" DisplayMemberPath="ShopName" />
                <TextBlock Text="Vehicle" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                <ComboBox ItemsSource="{Binding Vehicles}" SelectedItem="{Binding SelectedVehicle}" DisplayMemberPath="VehicleNumber" />
                <WrapPanel Margin="0,16,0,0">
                    <Button Content="Add Line" Command="{Binding AddLineCommand}" Style="{StaticResource SecondaryActionButton}" />
                    <Button Content="Checkout Cash Sale" Command="{Binding CheckoutCommand}" Style="{StaticResource PrimaryActionButton}" Margin="0" />
                </WrapPanel>
                <TextBlock Text="{Binding TotalLines, StringFormat=Items: {0}}" Margin="0,16,0,0" Style="{StaticResource CaptionText}" />
                <TextBlock Text="{Binding GrandTotal, StringFormat=Grand Total: {0:N2}}" FontSize="24" FontWeight="Bold" Margin="0,16,0,0" />
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusMessageText}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                    <DockPanel>
                        <TextBlock Text="POS Items" Style="{StaticResource CardTitleText}" DockPanel.Dock="Top" />
                        <DataGrid ItemsSource="{Binding Lines}">
                    <DataGrid.Columns>
                        <DataGridComboBoxColumn Header="Product" Width="*" SelectedItemBinding="{Binding Product}" DisplayMemberPath="Name" SelectedValuePath="."
                            ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="120" />
                        <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice}" Width="140" />
                        <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal}" Width="140" IsReadOnly="True" />
                    </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
