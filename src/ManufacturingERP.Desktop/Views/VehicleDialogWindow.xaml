<Window x:Class="ManufacturingERP.Desktop.Views.VehicleDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Vehicle"
        Height="520"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppCanvasBrush}">
    <Grid Margin="18">
        <Border Style="{StaticResource SectionCard}" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Vehicle Profile" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Capture fleet identity, driver assignment, and sales ownership."
                               Style="{StaticResource PageSubtitleText}" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Vehicle Number" Style="{StaticResource FormLabel}" />
                    <TextBox Text="{Binding VehicleNumber}" materialDesign:HintAssist.Hint="Vehicle number" />
                    <TextBlock Text="Description" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                    <TextBox Text="{Binding Description}" materialDesign:HintAssist.Hint="Vehicle description" />
                    <TextBlock Text="Driver" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                    <TextBox Text="{Binding DriverName}" materialDesign:HintAssist.Hint="Assigned driver" />
                    <TextBlock Text="Sales Rep" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                    <TextBox Text="{Binding SalesRepName}" materialDesign:HintAssist.Hint="Assigned sales representative" />
                    <CheckBox Content="Active" IsChecked="{Binding IsActive}" Margin="0,16,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="Save" Width="110" Margin="0,0,8,0" Click="Save_Click" />
                    <Button Content="Cancel" Width="110" Click="Cancel_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
