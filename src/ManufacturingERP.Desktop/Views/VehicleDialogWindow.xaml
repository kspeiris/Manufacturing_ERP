<Window x:Class="ManufacturingERP.Desktop.Views.VehicleDialogWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Vehicle" Height="560" Width="520" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="{StaticResource AppBackgroundBrush}">
    <Border Margin="20" Style="{StaticResource ViewRootCard}">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Vehicle" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Maintain fleet identity, description, and field assignments with a cleaner edit form." Style="{StaticResource PageSubtitleText}" Margin="0,0,0,20" />
                    <TextBlock Text="Vehicle Number" Style="{StaticResource FormLabel}" />
                    <TextBox Text="{Binding VehicleNumber}" />
                    <TextBlock Text="Description" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Text="{Binding Description}" />
                    <TextBlock Text="Driver" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Text="{Binding DriverName}" />
                    <TextBlock Text="Sales Rep" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Text="{Binding SalesRepName}" />
                    <CheckBox Content="Active" IsChecked="{Binding IsActive}" />
                </StackPanel>
            </ScrollViewer>
            <WrapPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Save" Width="110" Style="{StaticResource PrimaryActionButton}" Click="Save_Click" />
                <Button Content="Cancel" Width="110" Style="{StaticResource SecondaryActionButton}" Margin="0" Click="Cancel_Click" />
            </WrapPanel>
        </Grid>
    </Border>
</Window>
