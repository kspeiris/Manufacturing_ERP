<UserControl x:Class="ManufacturingERP.Desktop.Views.AuditLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Border Style="{StaticResource ViewRootCard}">
        <DockPanel>
            <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,14">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Audit Logs" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Review who changed what and when across the ERP workspace." Style="{StaticResource PageSubtitleText}" />
                </StackPanel>
                <Button Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryActionButton}" Margin="0" />
            </DockPanel>
            <DataGrid ItemsSource="{Binding AuditLogs}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="When (UTC)" Binding="{Binding ActionAtUtc}" Width="180" />
                    <DataGridTextColumn Header="User" Binding="{Binding User.Username}" Width="120" />
                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="100" />
                    <DataGridTextColumn Header="Entity" Binding="{Binding EntityName}" Width="120" />
                    <DataGridTextColumn Header="Key" Binding="{Binding EntityKey}" Width="100" />
                    <DataGridTextColumn Header="Old Values" Binding="{Binding OldValues}" Width="*" />
                    <DataGridTextColumn Header="New Values" Binding="{Binding NewValues}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
