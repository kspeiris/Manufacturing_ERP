<UserControl x:Class="ManufacturingERP.Desktop.Views.RoutesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,8">
            <Border Style="{StaticResource HeroCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="Routes" Style="{StaticResource HeroTitleText}" />
                        <TextBlock Text="Territory planning" Style="{StaticResource HeroEyebrowText}" Margin="0,6,0,0" />
                        <TextBlock Text="Maintain route planning, territory ownership, and notes with a cleaner operational directory."
                                   Style="{StaticResource HeroBodyText}" Margin="0,12,0,0" MaxWidth="700" />
                    </StackPanel>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="12" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <WrapPanel HorizontalAlignment="Right">
                            <Button Content="New" Command="{Binding AddCommand}" Style="{StaticResource PageActionButton}" />
                            <Button Content="Edit" Command="{Binding EditCommand}" Style="{StaticResource PageActionButton}" />
                            <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource PageDangerButton}" />
                            <Button Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource PageActionButton}" Margin="0" />
                        </WrapPanel>
                        <Border Grid.Row="2" Background="#172554" BorderBrush="#2563EB" BorderThickness="1" CornerRadius="18" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Directory Search" Foreground="#93C5FD" FontWeight="SemiBold" />
                                <TextBox Margin="0,12,0,0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search by code, name, territory, or notes" />
                                <TextBlock Text="{Binding StatusMessage}" Foreground="#CBD5E1" Margin="0,10,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,16"><StackPanel><TextBlock Text="Routes Loaded" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding Routes.Count}" Style="{StaticResource InlineStatValue}" /><TextBlock Text="Current visible route records." Style="{StaticResource PageSubtitleText}" /></StackPanel></Border>
                <Border Grid.Column="1" Style="{StaticResource SectionCard}" Margin="0,0,16,16"><StackPanel><TextBlock Text="Search Scope" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="Code, name, territory, or notes" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" /></StackPanel></Border>
                <Border Grid.Column="2" Style="{StaticResource SectionCard}" Margin="0,0,0,16"><StackPanel><TextBlock Text="Selected Route" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding SelectedRoute.Name, TargetNullValue=No route selected}" Style="{StaticResource InlineStatValue}" /><TextBlock Text="{Binding SelectedRoute.Territory, StringFormat=Territory: {0}, TargetNullValue=Choose a row from the directory}" Style="{StaticResource PageSubtitleText}" /></StackPanel></Border>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.15*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,16">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                            <TextBlock Text="Route Directory" Style="{StaticResource CardTitleText}" />
                            <TextBlock Text="Review territory setup and active routing before assigning customers and vehicles." Style="{StaticResource PageSubtitleText}" Margin="0" />
                        </StackPanel>
                        <Border Background="#F8FBFF" BorderBrush="#DCE7F5" BorderThickness="1" CornerRadius="18" Padding="8">
                            <DataGrid ItemsSource="{Binding Routes}" SelectedItem="{Binding SelectedRoute}" AutoGenerateColumns="False" CanUserAddRows="False" MaxHeight="460" MinWidth="860">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="120" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220" />
                                    <DataGridTextColumn Header="Territory" Binding="{Binding Territory}" Width="180" />
                                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="240" />
                                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </DockPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Route Details" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Review the currently selected route before editing or reassignment." Style="{StaticResource PageSubtitleText}" Margin="0,-2,0,18" />
                        <Border Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,12"><StackPanel><TextBlock Text="Route / Territory" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding SelectedRoute.Name, TargetNullValue=No route selected}" Style="{StaticResource InlineStatValue}" /><TextBlock Text="{Binding SelectedRoute.Territory, StringFormat=Territory: {0}, TargetNullValue=Territory: -}" Style="{StaticResource PageSubtitleText}" /></StackPanel></Border>
                        <Border Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="16" Padding="16"><StackPanel><TextBlock Text="Operational Notes" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding SelectedRoute.IsActive, StringFormat=Active: {0}, TargetNullValue=Active: -}" Style="{StaticResource PageSubtitleText}" /><TextBlock Text="{Binding SelectedRoute.Notes, TargetNullValue=No notes recorded.}" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" TextWrapping="Wrap" /></StackPanel></Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
