<UserControl x:Class="ManufacturingERP.Desktop.Views.RoutesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <DockPanel Margin="0,0,0,18">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Routes" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Maintain route planning, territory ownership, and notes with a cleaner operational directory."
                               Style="{StaticResource PageSubtitleText}" />
                </StackPanel>
                <WrapPanel HorizontalAlignment="Right">
                    <Button Content="New" Command="{Binding AddCommand}" Margin="0,0,8,0" />
                    <Button Content="Edit" Command="{Binding EditCommand}" Margin="0,0,8,0" />
                    <Button Content="Delete" Command="{Binding DeleteCommand}" Margin="0,0,8,0" />
                    <Button Content="Refresh" Command="{Binding LoadCommand}" />
                </WrapPanel>
            </DockPanel>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource InlineStatCard}" Margin="0,0,16,0"><StackPanel><TextBlock Text="Routes Loaded" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding Routes.Count}" Style="{StaticResource InlineStatValue}" /></StackPanel></Border>
                <Border Grid.Column="1" Style="{StaticResource InlineStatCard}" Margin="0,0,16,0"><StackPanel><TextBlock Text="Search Scope" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="Code, name, territory, or notes" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" /></StackPanel></Border>
                <Border Grid.Column="2" Style="{StaticResource UtilityPanel}"><StackPanel><TextBlock Text="Directory Search" Style="{StaticResource InlineStatLabel}" /><TextBox Margin="0,12,0,0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search by code, name, territory, or notes" /><TextBlock Text="{Binding StatusMessage}" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" /></StackPanel></Border>
            </Grid>

            <Border Style="{StaticResource SectionCard}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="Route Directory" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Review territory setup and active routing before assigning customers and vehicles."
                                   Style="{StaticResource PageSubtitleText}"
                                   Margin="0" />
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Routes}" SelectedItem="{Binding SelectedRoute}" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="120" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Territory" Binding="{Binding Territory}" Width="180" />
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="220" />
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
