<UserControl x:Class="ManufacturingERP.Desktop.Views.WarehousesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,8">
            <Border Style="{StaticResource HeroCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="Warehouses" Style="{StaticResource HeroTitleText}" />
                        <TextBlock Text="Storage directory" Style="{StaticResource HeroEyebrowText}" Margin="0,6,0,0" />
                        <TextBlock Text="Keep storage locations organized and searchable for receiving, stock control, and returns."
                                   Style="{StaticResource HeroBodyText}" Margin="0,12,0,0" MaxWidth="700" />
                    </StackPanel>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="12" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <WrapPanel HorizontalAlignment="Right">
                            <Button Content="New" Command="{Binding AddCommand}" Style="{StaticResource PageActionButton}" />
                            <Button Content="Edit" Command="{Binding EditCommand}" Style="{StaticResource PageActionButton}" />
                            <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource PageDangerButton}" />
                            <Button Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource PageActionButton}" Margin="0" />
                        </WrapPanel>
                        <Border Grid.Row="2" Background="#172554" BorderBrush="#2563EB" BorderThickness="1" CornerRadius="18" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Directory Search" Foreground="#93C5FD" FontWeight="SemiBold" />
                                <TextBox Margin="0,12,0,0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search by warehouse or location" />
                                <TextBlock Text="{Binding StatusMessage}" Foreground="#CBD5E1" Margin="0,10,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,16"><StackPanel><TextBlock Text="Warehouses Loaded" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding Warehouses.Count}" Style="{StaticResource InlineStatValue}" /><TextBlock Text="Current visible storage locations." Style="{StaticResource PageSubtitleText}" /></StackPanel></Border>
                <Border Grid.Column="1" Style="{StaticResource SectionCard}" Margin="0,0,16,16"><StackPanel><TextBlock Text="Search Scope" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="Warehouse or location" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" /></StackPanel></Border>
                <Border Grid.Column="2" Style="{StaticResource SectionCard}" Margin="0,0,0,16"><StackPanel><TextBlock Text="Selected Warehouse" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding SelectedWarehouse.Name, TargetNullValue=No warehouse selected}" Style="{StaticResource InlineStatValue}" /><TextBlock Text="{Binding SelectedWarehouse.Location, StringFormat=Location: {0}, TargetNullValue=Choose a row from the directory}" Style="{StaticResource PageSubtitleText}" /></StackPanel></Border>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.15*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,16">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                            <TextBlock Text="Warehouse Directory" Style="{StaticResource CardTitleText}" />
                            <TextBlock Text="Use the warehouse list to confirm active storage points and locations." Style="{StaticResource PageSubtitleText}" Margin="0" />
                        </StackPanel>
                        <Border Background="#F8FBFF" BorderBrush="#DCE7F5" BorderThickness="1" CornerRadius="18" Padding="8">
                            <DataGrid ItemsSource="{Binding Warehouses}" SelectedItem="{Binding SelectedWarehouse}" AutoGenerateColumns="False" CanUserAddRows="False" MaxHeight="460" MinWidth="700">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="240" />
                                    <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="260" />
                                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </DockPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Warehouse Details" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Review the currently selected storage point before editing or deleting." Style="{StaticResource PageSubtitleText}" Margin="0,-2,0,18" />
                        <Border Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,12"><StackPanel><TextBlock Text="Warehouse / Location" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding SelectedWarehouse.Name, TargetNullValue=No warehouse selected}" Style="{StaticResource InlineStatValue}" /><TextBlock Text="{Binding SelectedWarehouse.Location, StringFormat=Location: {0}, TargetNullValue=Location: -}" Style="{StaticResource PageSubtitleText}" /></StackPanel></Border>
                        <Border Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="16" Padding="16"><StackPanel><TextBlock Text="Operational State" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding SelectedWarehouse.IsActive, StringFormat=Active: {0}, TargetNullValue=Active: -}" Style="{StaticResource PageSubtitleText}" /></StackPanel></Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
