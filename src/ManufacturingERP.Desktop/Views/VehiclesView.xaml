<UserControl x:Class="ManufacturingERP.Desktop.Views.VehiclesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <DockPanel Margin="0,0,0,18">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Vehicles" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Manage fleet records, route drivers, and sales reps with a clearer transport directory."
                               Style="{StaticResource PageSubtitleText}" />
                </StackPanel>
                <WrapPanel HorizontalAlignment="Right">
                    <Button Content="New" Command="{Binding AddCommand}" Margin="0,0,8,0" />
                    <Button Content="Edit" Command="{Binding EditCommand}" Margin="0,0,8,0" />
                    <Button Content="Delete" Command="{Binding DeleteCommand}" Margin="0,0,8,0" />
                    <Button Content="Refresh" Command="{Binding LoadCommand}" />
                </WrapPanel>
            </DockPanel>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource InlineStatCard}" Margin="0,0,16,0"><StackPanel><TextBlock Text="Vehicles Loaded" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding Vehicles.Count}" Style="{StaticResource InlineStatValue}" /></StackPanel></Border>
                <Border Grid.Column="1" Style="{StaticResource InlineStatCard}" Margin="0,0,16,0"><StackPanel><TextBlock Text="Search Scope" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="Vehicle, description, driver, or rep" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" /></StackPanel></Border>
                <Border Grid.Column="2" Style="{StaticResource UtilityPanel}"><StackPanel><TextBlock Text="Directory Search" Style="{StaticResource InlineStatLabel}" /><TextBox Margin="0,12,0,0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search by vehicle, description, driver, or rep" /><TextBlock Text="{Binding StatusMessage}" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" /></StackPanel></Border>
            </Grid>

            <Border Style="{StaticResource SectionCard}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="Fleet Directory" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Use the fleet register to validate active delivery vehicles and assigned operators."
                                   Style="{StaticResource PageSubtitleText}"
                                   Margin="0" />
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Vehicles}" SelectedItem="{Binding SelectedVehicle}" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Vehicle No" Binding="{Binding VehicleNumber}" Width="140" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="Driver" Binding="{Binding DriverName}" Width="150" />
                            <DataGridTextColumn Header="Sales Rep" Binding="{Binding SalesRepName}" Width="150" />
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
