<UserControl x:Class="ManufacturingERP.Desktop.Views.VehiclesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Border Background="White" CornerRadius="18" Padding="18">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                <DockPanel>
                    <TextBlock Text="Vehicles" FontSize="28" FontWeight="Bold" />
                    <WrapPanel HorizontalAlignment="Right">
                        <Button Content="New" Command="{Binding AddCommand}" Margin="0,0,8,0" />
                        <Button Content="Edit" Command="{Binding EditCommand}" Margin="0,0,8,0" />
                        <Button Content="Delete" Command="{Binding DeleteCommand}" Margin="0,0,8,0" />
                        <Button Content="Refresh" Command="{Binding LoadCommand}" />
                    </WrapPanel>
                </DockPanel>
                <TextBox Margin="0,12,0,0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search by vehicle, description, driver, or rep" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#2563EB" Margin="0,8,0,0" />
            </StackPanel>
            <DataGrid ItemsSource="{Binding Vehicles}" SelectedItem="{Binding SelectedVehicle}" AutoGenerateColumns="False" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Vehicle No" Binding="{Binding VehicleNumber}" Width="140" />
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                    <DataGridTextColumn Header="Driver" Binding="{Binding DriverName}" Width="150" />
                    <DataGridTextColumn Header="Sales Rep" Binding="{Binding SalesRepName}" Width="150" />
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
