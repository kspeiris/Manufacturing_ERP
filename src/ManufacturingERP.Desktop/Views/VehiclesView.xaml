<UserControl x:Class="ManufacturingERP.Desktop.Views.VehiclesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Border Style="{StaticResource ViewRootCard}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <DockPanel LastChildFill="False" Margin="0,0,0,14">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Vehicles" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Track fleet identity, assignments, and active status for field sales operations." Style="{StaticResource PageSubtitleText}" />
                </StackPanel>
                <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Content="New" Command="{Binding AddCommand}" Style="{StaticResource PrimaryActionButton}" />
                    <Button Content="Edit" Command="{Binding EditCommand}" Style="{StaticResource SecondaryActionButton}" />
                    <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource DangerActionButton}" />
                    <Button Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryActionButton}" Margin="0" />
                </WrapPanel>
            </DockPanel>
            <StackPanel Grid.Row="1" Margin="0,0,0,14">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search by vehicle, description, driver, or rep" />
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusMessageText}" />
            </StackPanel>
            <DataGrid Grid.Row="2" ItemsSource="{Binding Vehicles}" SelectedItem="{Binding SelectedVehicle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Vehicle No" Binding="{Binding VehicleNumber}" Width="140" />
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                    <DataGridTextColumn Header="Driver" Binding="{Binding DriverName}" Width="150" />
                    <DataGridTextColumn Header="Sales Rep" Binding="{Binding SalesRepName}" Width="150" />
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
