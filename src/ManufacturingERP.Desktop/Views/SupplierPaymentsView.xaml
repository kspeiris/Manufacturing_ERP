<UserControl x:Class="ManufacturingERP.Desktop.Views.SupplierPaymentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Supplier Payments" Style="{StaticResource PageTitleText}" />
            <TextBlock Text="Review open invoices, record payment details, and confirm the selected balance before posting." Style="{StaticResource PageSubtitleText}" Margin="0,0,0,18" />
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="1.1*"/><ColumnDefinition Width="1.9*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                    <StackPanel>
                <TextBlock Text="Supplier Payment Entry" Style="{StaticResource CardTitleText}" />
                <TextBlock Text="Supplier" Style="{StaticResource FormLabel}" />
                <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="Name" />
                <TextBlock Text="Open Invoice" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                <ComboBox ItemsSource="{Binding OpenInvoices}" SelectedItem="{Binding SelectedInvoice}" DisplayMemberPath="InvoiceNo" />
                <TextBlock Text="Reference Invoice" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                <TextBox Text="{Binding ReferenceInvoiceNo}" />
                <TextBlock Text="{Binding SelectedInvoiceBalance, StringFormat=Selected Balance: {0:N2}}" Style="{StaticResource CaptionText}" Margin="0,6,0,0" />
                <TextBlock Text="Amount" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                <TextBox Text="{Binding Amount}" />
                <TextBlock Text="Payment Method" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                <TextBox Text="{Binding PaymentMethod}" />
                <TextBlock Text="Notes" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                <TextBox Text="{Binding Notes}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" />
                <WrapPanel Margin="0,16,0,0">
                    <Button Content="Save Payment" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryActionButton}" />
                    <Button Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryActionButton}" Margin="0" />
                </WrapPanel>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusMessageText}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                    <DockPanel>
                        <TextBlock Text="Recent Supplier Payments" Style="{StaticResource CardTitleText}" DockPanel.Dock="Top" />
                        <DataGrid ItemsSource="{Binding Payments}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Payment No" Binding="{Binding PaymentNo}" Width="160" />
                        <DataGridTextColumn Header="Date" Binding="{Binding PaymentDate}" Width="150" />
                        <DataGridTextColumn Header="Supplier" Binding="{Binding Supplier.Name}" Width="*" />
                        <DataGridTextColumn Header="Ref Invoice" Binding="{Binding ReferenceInvoiceNo}" Width="140" />
                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="120" />
                        <DataGridTextColumn Header="Method" Binding="{Binding PaymentMethod}" Width="120" />
                    </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
