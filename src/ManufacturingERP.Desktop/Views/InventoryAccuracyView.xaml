<UserControl x:Class="ManufacturingERP.Desktop.Views.InventoryAccuracyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Inventory Accuracy" Style="{StaticResource PageTitleText}" />
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource PageSubtitleText}" Margin="0,0,0,16" />

            <TabControl>
                <TabItem Header="Batch Tracking">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="1.95*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="Batch Lot" Style="{StaticResource CardTitleText}" />
                                <TextBlock Text="Product" Style="{StaticResource FormLabel}" />
                                <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" DisplayMemberPath="Name" />
                                <TextBlock Text="Warehouse" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <ComboBox ItemsSource="{Binding Warehouses}" SelectedItem="{Binding SelectedWarehouse}" DisplayMemberPath="Name" />
                                <TextBlock Text="Bin" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <ComboBox ItemsSource="{Binding WarehouseBins}" SelectedItem="{Binding SelectedWarehouseBin}" DisplayMemberPath="BinCode" />
                                <TextBlock Text="Lot No" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <TextBox Text="{Binding LotNumber}" />
                                <TextBlock Text="Manufactured" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <DatePicker SelectedDate="{Binding ManufacturingDate}" />
                                <TextBlock Text="Expires" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <DatePicker SelectedDate="{Binding ExpiryDate}" />
                                <TextBlock Text="Qty on Hand" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <TextBox Text="{Binding LotQuantity}" />
                                <WrapPanel Margin="0,16,0,0">
                                    <Button Content="New" Command="{Binding NewBatchLotCommand}" Margin="0,0,8,0" />
                                    <Button Content="Save" Command="{Binding SaveBatchLotCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                            <DataGrid ItemsSource="{Binding BatchLots}" SelectedItem="{Binding SelectedBatchLot}" AutoGenerateColumns="False" CanUserAddRows="False" Height="540">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Lot" Binding="{Binding LotNumber}" Width="150" />
                                    <DataGridTextColumn Header="Product" Binding="{Binding Product.Name}" Width="*" />
                                    <DataGridTextColumn Header="Warehouse" Binding="{Binding Warehouse.Name}" Width="160" />
                                    <DataGridTextColumn Header="Bin" Binding="{Binding WarehouseBin.BinCode}" Width="120" />
                                    <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryDate, StringFormat=d}" Width="120" />
                                    <DataGridTextColumn Header="On Hand" Binding="{Binding QuantityOnHand}" Width="110" />
                                    <DataGridTextColumn Header="Reserved" Binding="{Binding QuantityReserved}" Width="110" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Stock Transfers">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="1.95*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="Transfer Request" Style="{StaticResource CardTitleText}" />
                                <TextBlock Text="From Warehouse" Style="{StaticResource FormLabel}" />
                                <ComboBox ItemsSource="{Binding Warehouses}" SelectedItem="{Binding TransferFromWarehouse}" DisplayMemberPath="Name" />
                                <TextBlock Text="To Warehouse" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <ComboBox ItemsSource="{Binding Warehouses}" SelectedItem="{Binding TransferToWarehouse}" DisplayMemberPath="Name" />
                                <TextBlock Text="Product" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding TransferProduct}" DisplayMemberPath="Name" />
                                <TextBlock Text="Quantity" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <TextBox Text="{Binding TransferQuantity}" />
                                <TextBlock Text="Notes" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <TextBox Text="{Binding TransferNotes}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" />
                                <Button Content="Create Transfer" Command="{Binding CreateStockTransferCommand}" Margin="0,16,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                            <DockPanel>
                                <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <Button Content="Submit" Command="{Binding SubmitTransferCommand}" Margin="0,0,8,8" />
                                    <Button Content="Approve" Command="{Binding ApproveTransferCommand}" Margin="0,0,8,8" />
                                    <Button Content="Dispatch" Command="{Binding DispatchTransferCommand}" Margin="0,0,8,8" />
                                    <Button Content="Receive" Command="{Binding ReceiveTransferCommand}" Margin="0,0,8,8" />
                                    <Button Content="Cancel" Command="{Binding CancelTransferCommand}" Margin="0,0,8,8" />
                                    <Button Content="Refresh" Command="{Binding LoadCommand}" />
                                </WrapPanel>
                                <DataGrid ItemsSource="{Binding StockTransfers}" SelectedItem="{Binding SelectedStockTransfer}" AutoGenerateColumns="False" CanUserAddRows="False" Height="540">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="No" Binding="{Binding TransferNo}" Width="160" />
                                        <DataGridTextColumn Header="Date" Binding="{Binding TransferDate, StringFormat=d}" Width="110" />
                                        <DataGridTextColumn Header="From" Binding="{Binding FromWarehouse.Name}" Width="150" />
                                        <DataGridTextColumn Header="To" Binding="{Binding ToWarehouse.Name}" Width="150" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130" />
                                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Reorder Levels">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="1.95*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="Product Controls" Style="{StaticResource CardTitleText}" />
                                <TextBlock Text="Product" Style="{StaticResource FormLabel}" />
                                <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" DisplayMemberPath="Name" />
                                <TextBlock Text="Reorder Level" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <TextBox Text="{Binding SelectedProductReorderLevel}" />
                                <CheckBox Content="Track batches" IsChecked="{Binding SelectedProductTrackBatch}" Margin="0,12,0,0" />
                                <Button Content="Save Controls" Command="{Binding SaveReorderLevelCommand}" Margin="0,16,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                            <DataGrid ItemsSource="{Binding ReorderAlerts}" AutoGenerateColumns="False" CanUserAddRows="False" Height="540">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Code" Binding="{Binding ProductCode}" Width="110" />
                                    <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                                    <DataGridTextColumn Header="Warehouse" Binding="{Binding WarehouseName}" Width="160" />
                                    <DataGridTextColumn Header="On Hand" Binding="{Binding QuantityOnHand}" Width="110" />
                                    <DataGridTextColumn Header="Reserved" Binding="{Binding QuantityReserved}" Width="110" />
                                    <DataGridTextColumn Header="Available" Binding="{Binding QuantityAvailable}" Width="110" />
                                    <DataGridTextColumn Header="Reorder" Binding="{Binding ReorderLevel}" Width="110" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Physical Counts">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="1.95*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="Count Entry" Style="{StaticResource CardTitleText}" />
                                <TextBlock Text="Warehouse" Style="{StaticResource FormLabel}" />
                                <ComboBox ItemsSource="{Binding Warehouses}" SelectedItem="{Binding CountWarehouse}" DisplayMemberPath="Name" />
                                <TextBlock Text="Product" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding CountProduct}" DisplayMemberPath="Name" />
                                <TextBlock Text="Batch Lot" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <ComboBox ItemsSource="{Binding BatchLots}" SelectedItem="{Binding CountBatchLot}" DisplayMemberPath="LotNumber" />
                                <TextBlock Text="Book Qty" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <TextBox Text="{Binding BookQuantity}" />
                                <TextBlock Text="Counted Qty" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <TextBox Text="{Binding CountedQuantity}" />
                                <TextBlock Text="Notes" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                                <TextBox Text="{Binding CountNotes}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" />
                                <Button Content="Create Count" Command="{Binding CreateStockCountCommand}" Margin="0,16,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                            <DockPanel>
                                <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <Button Content="Start" Command="{Binding StartCountCommand}" Margin="0,0,8,8" />
                                    <Button Content="Submit" Command="{Binding SubmitCountCommand}" Margin="0,0,8,8" />
                                    <Button Content="Approve" Command="{Binding ApproveCountCommand}" Margin="0,0,8,8" />
                                    <Button Content="Refresh" Command="{Binding LoadCommand}" />
                                </WrapPanel>
                                <DataGrid ItemsSource="{Binding StockCounts}" SelectedItem="{Binding SelectedStockCount}" AutoGenerateColumns="False" CanUserAddRows="False" Height="540">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="No" Binding="{Binding CountNo}" Width="160" />
                                        <DataGridTextColumn Header="Date" Binding="{Binding CountDate, StringFormat=d}" Width="110" />
                                        <DataGridTextColumn Header="Warehouse" Binding="{Binding Warehouse.Name}" Width="160" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130" />
                                        <DataGridTextColumn Header="Lines" Binding="{Binding TotalLineCount}" Width="90" />
                                        <DataGridTextColumn Header="Variance Lines" Binding="{Binding VarianceLineCount}" Width="120" />
                                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
