<UserControl x:Class="ManufacturingERP.Desktop.Views.ReportViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="1.1*"/><ColumnDefinition Width="1.9*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
            <StackPanel>
                <WrapPanel Margin="0,0,0,12">
                    <TextBlock Text="Report Center" Style="{StaticResource CardTitleText}" Margin="0,0,8,0" />
                    <Button Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryActionButton}" Margin="0" />
                </WrapPanel>
                <TextBlock Text="Exported Files" Style="{StaticResource FormLabel}" />
                <ListBox x:Name="ExportFilesList" ItemsSource="{Binding ExportFiles}" SelectedItem="{Binding SelectedFilePath}" SelectionChanged="ExportFilesList_OnSelectionChanged" Height="220" Margin="0,0,0,12" />
                <TextBlock Text="Templates" Style="{StaticResource FormLabel}" />
                <ListBox ItemsSource="{Binding TemplateFiles}" Height="180" />
                <Button Content="Select File" Command="{Binding OpenSelectedFileCommand}" Style="{StaticResource PrimaryActionButton}" Margin="0,12,0,0" />
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusMessageText}" />
            </StackPanel>
        </Border>
        <Border Grid.Column="1" Style="{StaticResource SectionCard}">
            <DockPanel>
                <TextBlock Text="Embedded Preview" Style="{StaticResource CardTitleText}" DockPanel.Dock="Top" />
                <WebBrowser x:Name="PreviewBrowser" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
