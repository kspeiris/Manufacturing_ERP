<UserControl x:Class="ManufacturingERP.Desktop.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <DockPanel Margin="0,0,0,18">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Products" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Keep pricing, units, product status, and catalog structure clean for every downstream workflow."
                               Style="{StaticResource PageSubtitleText}" />
                </StackPanel>
                <WrapPanel HorizontalAlignment="Right">
                    <Button Content="New" Command="{Binding AddCommand}" Margin="0,0,8,0" />
                    <Button Content="Edit" Command="{Binding EditCommand}" Margin="0,0,8,0" />
                    <Button Content="Delete" Command="{Binding DeleteCommand}" Margin="0,0,8,0" />
                    <Button Content="Refresh" Command="{Binding LoadCommand}" />
                </WrapPanel>
            </DockPanel>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource InlineStatCard}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Products Loaded" Style="{StaticResource InlineStatLabel}" />
                        <TextBlock Text="{Binding Products.Count}" Style="{StaticResource InlineStatValue}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource InlineStatCard}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Search Scope" Style="{StaticResource InlineStatLabel}" />
                        <TextBlock Text="Code, name, unit, and category" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource UtilityPanel}">
                    <StackPanel>
                        <TextBlock Text="Directory Search" Style="{StaticResource InlineStatLabel}" />
                        <TextBox Margin="0,12,0,0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search by code, name, unit, or category" />
                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource SectionCard}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="Product Directory" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Select a product to edit pricing, category assignment, or active status."
                                   Style="{StaticResource PageSubtitleText}"
                                   Margin="0" />
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" RowHeight="34">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="120" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Category" Binding="{Binding ProductCategory.Name}" Width="200" />
                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="90" />
                            <DataGridTextColumn Header="Cost" Binding="{Binding CostPrice}" Width="120" />
                            <DataGridTextColumn Header="Selling" Binding="{Binding SellingPrice}" Width="120" />
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
