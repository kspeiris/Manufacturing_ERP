<UserControl x:Class="ManufacturingERP.Desktop.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Border Style="{StaticResource ViewRootCard}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <DockPanel LastChildFill="False" Margin="0,0,0,14">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Products" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Keep pricing, units, product status, and catalog structure clean for every downstream workflow." Style="{StaticResource PageSubtitleText}" />
                </StackPanel>
                <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Content="New" Command="{Binding AddCommand}" Style="{StaticResource PrimaryActionButton}" />
                    <Button Content="Edit" Command="{Binding EditCommand}" Style="{StaticResource SecondaryActionButton}" />
                    <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource DangerActionButton}" />
                    <Button Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryActionButton}" Margin="0" />
                </WrapPanel>
            </DockPanel>
            <StackPanel Grid.Row="1" Margin="0,0,0,14">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search by code, name, unit, or category" />
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusMessageText}" />
            </StackPanel>
            <DataGrid Grid.Row="2" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="120" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Category" Binding="{Binding ProductCategory.Name}" Width="200" />
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="90" />
                    <DataGridTextColumn Header="Cost" Binding="{Binding CostPrice}" Width="120" />
                    <DataGridTextColumn Header="Selling" Binding="{Binding SellingPrice}" Width="120" />
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
