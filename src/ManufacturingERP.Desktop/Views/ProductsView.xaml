<UserControl x:Class="ManufacturingERP.Desktop.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="ProductActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="ProductDeleteButton" TargetType="Button" BasedOn="{StaticResource ProductActionButton}">
            <Setter Property="Background" Value="#FEE2E2" />
            <Setter Property="BorderBrush" Value="#FCA5A5" />
            <Setter Property="Foreground" Value="#DC2626" />
        </Style>

        <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource SectionCard}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,16,16" />
            <Setter Property="Width" Value="248" />
        </Style>

        <Style x:Key="TabChipButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="MinWidth" Value="124" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Background" Value="#EAF1FA" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="BorderBrush" Value="#DCE7F5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DCE7F5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,8">
            <Border Style="{StaticResource HeroCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="Products"
                                   Style="{StaticResource HeroTitleText}" />
                        <TextBlock Text="Catalog command center"
                                   Style="{StaticResource HeroEyebrowText}"
                                   Margin="0,6,0,0" />
                        <TextBlock Text="Keep pricing, units, product status, and catalog structure clean for every downstream workflow."
                                   Style="{StaticResource HeroBodyText}"
                                   Margin="0,12,0,0"
                                   MaxWidth="720" />

                        <Border Margin="0,22,0,0"
                                Background="#162033"
                                BorderBrush="#233A63"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Products Loaded"
                                               Foreground="#93C5FD"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Products.Count}"
                                               Foreground="White"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="Records currently visible in the directory."
                                               Foreground="#CBD5E1"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                    <TextBlock Text="Active Products"
                                               Foreground="#93C5FD"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ActiveProductsCount}"
                                               Foreground="White"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="Items currently available for selling and downstream workflows."
                                               Foreground="#CBD5E1"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <WrapPanel HorizontalAlignment="Right">
                            <Button Content="New"
                                    Command="{Binding AddCommand}"
                                    Style="{StaticResource ProductActionButton}" />
                            <Button Content="Edit"
                                    Command="{Binding EditCommand}"
                                    Style="{StaticResource ProductActionButton}" />
                            <Button Content="Delete"
                                    Command="{Binding DeleteCommand}"
                                    Style="{StaticResource ProductDeleteButton}" />
                            <Button Content="Refresh"
                                    Command="{Binding LoadCommand}"
                                    Style="{StaticResource ProductActionButton}"
                                    Margin="0" />
                        </WrapPanel>

                        <Border Grid.Row="2"
                                Background="#172554"
                                BorderBrush="#2563EB"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="Directory Search"
                                           Foreground="#93C5FD"
                                           FontWeight="SemiBold" />
                                <TextBox Margin="0,12,0,0"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Search by code, name, unit, or category" />
                                <TextBlock Text="{Binding StatusMessage}"
                                           Foreground="#CBD5E1"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource SectionCard}" Margin="0,0,0,16">
                <StackPanel>
                    <Border Background="#F8FBFF"
                            BorderBrush="#DCE7F5"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14"
                            Margin="0,0,0,18">
                        <WrapPanel VerticalAlignment="Center">
                        <Button Content="Overview"
                                Command="{Binding SetActiveTabCommand}"
                                CommandParameter="Overview">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TabChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveTab}" Value="Overview">
                                            <Setter Property="Background" Value="#2563EB" />
                                            <Setter Property="BorderBrush" Value="#2563EB" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Directory"
                                Command="{Binding SetActiveTabCommand}"
                                CommandParameter="Directory">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TabChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveTab}" Value="Directory">
                                            <Setter Property="Background" Value="#2563EB" />
                                            <Setter Property="BorderBrush" Value="#2563EB" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        </WrapPanel>
                    </Border>

                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTab}" Value="Directory">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <StackPanel>
                            <WrapPanel Margin="0,0,0,4">
                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel>
                                        <TextBlock Text="Visible Products" Style="{StaticResource InlineStatLabel}" />
                                        <TextBlock Text="{Binding Products.Count}" Style="{StaticResource InlineStatValue}" />
                                        <TextBlock Text="Current records matching the search."
                                                   Style="{StaticResource PageSubtitleText}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel>
                                        <TextBlock Text="Active Products" Style="{StaticResource InlineStatLabel}" />
                                        <TextBlock Text="{Binding ActiveProductsCount}" Style="{StaticResource InlineStatValue}" />
                                        <TextBlock Text="Items available for normal workflows."
                                                   Style="{StaticResource PageSubtitleText}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel>
                                        <TextBlock Text="Inactive Products" Style="{StaticResource InlineStatLabel}" />
                                        <TextBlock Text="{Binding InactiveProductsCount}" Style="{StaticResource InlineStatValue}" />
                                        <TextBlock Text="Catalog rows currently disabled."
                                                   Style="{StaticResource PageSubtitleText}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource KpiCard}">
                                    <StackPanel>
                                        <TextBlock Text="Categories" Style="{StaticResource InlineStatLabel}" />
                                        <TextBlock Text="{Binding CategoryCount}" Style="{StaticResource InlineStatValue}" />
                                        <TextBlock Text="Distinct product groups in the filtered set."
                                                   Style="{StaticResource PageSubtitleText}" />
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.45*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,0">
                                    <StackPanel>
                                        <TextBlock Text="Catalog Overview" Style="{StaticResource CardTitleText}" />
                                        <TextBlock Text="Summary indicators for the currently visible product set."
                                                   Style="{StaticResource PageSubtitleText}"
                                                   Margin="0,-2,0,18" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" Grid.Column="0" Background="#F8FBFF" BorderBrush="#DCE7F5" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,12,12">
                                                <StackPanel>
                                                    <TextBlock Text="Average Selling Price" Style="{StaticResource InlineStatLabel}" />
                                                    <TextBlock Text="{Binding AverageSellingPrice, StringFormat=N2}" Style="{StaticResource InlineStatValue}" />
                                                    <TextBlock Text="Average listed selling price across visible records."
                                                               Style="{StaticResource PageSubtitleText}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="0" Grid.Column="1" Background="#F8FBFF" BorderBrush="#DCE7F5" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,12">
                                                <StackPanel>
                                                    <TextBlock Text="Batch Tracked" Style="{StaticResource InlineStatLabel}" />
                                                    <TextBlock Text="{Binding BatchTrackedCount}" Style="{StaticResource InlineStatValue}" />
                                                    <TextBlock Text="Products configured for tracked batch handling."
                                                               Style="{StaticResource PageSubtitleText}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="1" Grid.Column="0" Background="#F8FBFF" BorderBrush="#DCE7F5" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="Catalog Mix" Style="{StaticResource InlineStatLabel}" />
                                                    <TextBlock Text="{Binding CategoryCount, StringFormat={}{0} distinct categories in the visible set}"
                                                               Style="{StaticResource PageSubtitleText}"
                                                               Margin="0,8,0,0" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="1" Grid.Column="1" Background="#F8FBFF" BorderBrush="#DCE7F5" BorderThickness="1" CornerRadius="16" Padding="16">
                                                <StackPanel>
                                                    <TextBlock Text="Directory Status" Style="{StaticResource InlineStatLabel}" />
                                                    <TextBlock Text="{Binding StatusMessage, TargetNullValue=Use the search panel above to focus the catalog.}"
                                                               Style="{StaticResource PageSubtitleText}"
                                                               Margin="0,8,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Text="Selection Details" Style="{StaticResource CardTitleText}" />
                                        <TextBlock Text="Click a row in the directory to review the current product profile."
                                                   Style="{StaticResource PageSubtitleText}"
                                                   Margin="0,-2,0,18" />

                                        <Border Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="Selected Product" Style="{StaticResource InlineStatLabel}" />
                                                <TextBlock Text="{Binding SelectedProduct.Name, TargetNullValue=No product selected}" Style="{StaticResource InlineStatValue}" />
                                                <TextBlock Text="{Binding SelectedProduct.Code, StringFormat=Code: {0}, TargetNullValue=Choose a row from the directory}" Style="{StaticResource PageSubtitleText}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="Category / Unit" Style="{StaticResource InlineStatLabel}" />
                                                <TextBlock Text="{Binding SelectedProduct.ProductCategory.Name, TargetNullValue=-}" Style="{StaticResource InlineStatValue}" />
                                                <TextBlock Text="{Binding SelectedProduct.Unit, StringFormat=Unit: {0}, TargetNullValue=Unit: -}" Style="{StaticResource PageSubtitleText}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="16" Padding="16">
                                            <StackPanel>
                                                <TextBlock Text="Pricing" Style="{StaticResource InlineStatLabel}" />
                                                <TextBlock Text="{Binding SelectedProduct.SellingPrice, StringFormat=Selling: {0:N2}, TargetNullValue=Selling: -}" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" />
                                                <TextBlock Text="{Binding SelectedProduct.CostPrice, StringFormat=Cost: {0:N2}, TargetNullValue=Cost: -}" Style="{StaticResource PageSubtitleText}" />
                                                <TextBlock Text="{Binding SelectedProduct.IsActive, StringFormat=Active: {0}, TargetNullValue=Active: -}" Style="{StaticResource PageSubtitleText}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTab}" Value="Directory">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <StackPanel>
                            <Border Style="{StaticResource SectionCard}">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Product Directory" Style="{StaticResource CardTitleText}" />
                                            <TextBlock Text="Select a product to edit pricing, category assignment, active state, or batch settings. Horizontal scrolling stays available only when the directory grows wider."
                                                       Style="{StaticResource PageSubtitleText}"
                                                       Margin="0" />
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Background="#EEF2FF"
                                                BorderBrush="#C7D2FE"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                Padding="14,10"
                                                Margin="16,0,0,0"
                                                VerticalAlignment="Top">
                                            <StackPanel>
                                                <TextBlock Text="Filtered Rows"
                                                           Style="{StaticResource InlineStatLabel}" />
                                                <TextBlock Text="{Binding Products.Count}"
                                                           Style="{StaticResource InlineStatValue}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Background="#F8FBFF"
                                            BorderBrush="#DCE7F5"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="8">
                                        <DataGrid ItemsSource="{Binding Products}"
                                                  SelectedItem="{Binding SelectedProduct}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  HeadersVisibility="Column"
                                                  RowHeight="38"
                                                  MaxHeight="460"
                                                  MinWidth="1120"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="130" />
                                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="260" />
                                                <DataGridTextColumn Header="Category" Binding="{Binding ProductCategory.Name}" Width="220" />
                                                <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="90" />
                                                <DataGridTextColumn Header="Cost" Binding="{Binding CostPrice, StringFormat=N2}" Width="120" />
                                                <DataGridTextColumn Header="Selling" Binding="{Binding SellingPrice, StringFormat=N2}" Width="120" />
                                                <DataGridCheckBoxColumn Header="Track Batch" Binding="{Binding TrackBatch}" Width="120" />
                                                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
