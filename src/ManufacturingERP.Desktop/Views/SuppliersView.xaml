<UserControl x:Class="ManufacturingERP.Desktop.Views.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,8">
            <Border Style="{StaticResource HeroCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="Suppliers" Style="{StaticResource HeroTitleText}" />
                        <TextBlock Text="Procurement directory" Style="{StaticResource HeroEyebrowText}" Margin="0,6,0,0" />
                        <TextBlock Text="Keep supplier records, phone numbers, and addresses standardized for purchasing and payments."
                                   Style="{StaticResource HeroBodyText}" Margin="0,12,0,0" MaxWidth="700" />
                    </StackPanel>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <WrapPanel HorizontalAlignment="Right">
                            <Button Content="New" Command="{Binding AddCommand}" Style="{StaticResource PageActionButton}" />
                            <Button Content="Edit" Command="{Binding EditCommand}" Style="{StaticResource PageActionButton}" />
                            <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource PageDangerButton}" />
                            <Button Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource PageActionButton}" Margin="0" />
                        </WrapPanel>
                        <Border Grid.Row="2" Background="#172554" BorderBrush="#2563EB" BorderThickness="1" CornerRadius="18" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Selected Supplier" Foreground="#93C5FD" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedSupplier.Name, TargetNullValue=No supplier selected}" Foreground="White" FontSize="22" FontWeight="SemiBold" Margin="0,10,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedSupplier.SupplierCode, StringFormat=Code: {0}, TargetNullValue=Choose a row from the directory to inspect supplier details.}" Foreground="#CBD5E1" Margin="0,8,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding StatusMessage}" Foreground="#93C5FD" Margin="0,10,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,16"><StackPanel><TextBlock Text="Suppliers Loaded" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding Suppliers.Count}" Style="{StaticResource InlineStatValue}" /><TextBlock Text="Current visible supplier records." Style="{StaticResource PageSubtitleText}" /></StackPanel></Border>
                <Border Grid.Column="1" Style="{StaticResource SectionCard}" Margin="0,0,16,16"><StackPanel><TextBlock Text="Search Scope" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="Code, name, phone, or address" Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" /></StackPanel></Border>
                <Border Grid.Column="2" Style="{StaticResource SectionCard}" Margin="0,0,0,16"><StackPanel><TextBlock Text="Selected Supplier" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding SelectedSupplier.Name, TargetNullValue=No supplier selected}" Style="{StaticResource InlineStatValue}" /><TextBlock Text="{Binding SelectedSupplier.SupplierCode, StringFormat=Code: {0}, TargetNullValue=Choose a row from the directory}" Style="{StaticResource PageSubtitleText}" /></StackPanel></Border>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.15*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,16,16">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Supplier Directory" Style="{StaticResource CardTitleText}" />
                                <TextBlock Text="Review supplier records before procurement or supplier-payment activity." Style="{StaticResource PageSubtitleText}" Margin="0" />
                            </StackPanel>
                            <Border Grid.Column="1" Style="{StaticResource TableCountBadge}">
                                <TextBlock Text="{Binding Suppliers.Count, StringFormat=Total: {0}}" Style="{StaticResource TableCountText}" />
                            </Border>
                        </Grid>
                        <Border DockPanel.Dock="Top" Style="{StaticResource TableToolbarBorder}" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search by code, name, phone, or address" />
                                <Button Grid.Column="1" Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource PageActionButton}" Margin="12,0,0,0" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource TableShellBorder}" Padding="8">
                            <ScrollViewer Style="{StaticResource TableViewportScrollViewer}">
                            <DataGrid ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" AutoGenerateColumns="False" CanUserAddRows="False" MaxHeight="460" MinWidth="820">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Code" Binding="{Binding SupplierCode}" Width="120" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220" />
                                    <DataGridTextColumn Header="Phone" Binding="{Binding ContactNumber}" Width="150" />
                                    <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="260" />
                                    <DataGridTemplateColumn Header="Actions" Width="132">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource TableActionIconButton}" ToolTip="View" Command="{Binding DataContext.SelectSupplierCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                        <materialDesign:PackIcon Kind="EyeOutline" Width="18" Height="18" Foreground="#2563EB" />
                                                    </Button>
                                                    <Button Style="{StaticResource TableActionIconButton}" ToolTip="Edit" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                        <materialDesign:PackIcon Kind="PencilOutline" Width="18" Height="18" Foreground="#D97706" />
                                                    </Button>
                                                    <Button Style="{StaticResource TableActionIconButton}" ToolTip="Delete" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="0">
                                                        <materialDesign:PackIcon Kind="TrashCanOutline" Width="18" Height="18" Foreground="#DC2626" />
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            </ScrollViewer>
                        </Border>
                    </DockPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Supplier Details" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Review the currently selected supplier before changes are made." Style="{StaticResource PageSubtitleText}" Margin="0,-2,0,18" />
                        <Border Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,12"><StackPanel><TextBlock Text="Name / Code" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding SelectedSupplier.Name, TargetNullValue=No supplier selected}" Style="{StaticResource InlineStatValue}" /><TextBlock Text="{Binding SelectedSupplier.SupplierCode, StringFormat=Code: {0}, TargetNullValue=Code: -}" Style="{StaticResource PageSubtitleText}" /></StackPanel></Border>
                        <Border Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="16" Padding="16"><StackPanel><TextBlock Text="Contact" Style="{StaticResource InlineStatLabel}" /><TextBlock Text="{Binding SelectedSupplier.ContactNumber, TargetNullValue=-}" Style="{StaticResource InlineStatValue}" /><TextBlock Text="{Binding SelectedSupplier.Address, TargetNullValue=Address: -, StringFormat=Address: {0}}" Style="{StaticResource PageSubtitleText}" TextWrapping="Wrap" /></StackPanel></Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
