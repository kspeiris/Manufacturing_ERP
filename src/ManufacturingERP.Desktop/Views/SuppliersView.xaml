<UserControl x:Class="ManufacturingERP.Desktop.Views.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Border Style="{StaticResource ViewRootCard}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <DockPanel LastChildFill="False" Margin="0,0,0,14">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Suppliers" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Maintain supplier identities, contacts, and addresses so purchasing and payments stay accurate." Style="{StaticResource PageSubtitleText}" />
                </StackPanel>
                <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Content="New" Command="{Binding AddCommand}" Style="{StaticResource PrimaryActionButton}" />
                    <Button Content="Edit" Command="{Binding EditCommand}" Style="{StaticResource SecondaryActionButton}" />
                    <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource DangerActionButton}" />
                    <Button Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryActionButton}" Margin="0" />
                </WrapPanel>
            </DockPanel>
            <StackPanel Grid.Row="1" Margin="0,0,0,14">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search by code, name, phone, or address" />
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusMessageText}" />
            </StackPanel>
            <DataGrid Grid.Row="2" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding SupplierCode}" Width="120" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Phone" Binding="{Binding ContactNumber}" Width="140" />
                    <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="220" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
