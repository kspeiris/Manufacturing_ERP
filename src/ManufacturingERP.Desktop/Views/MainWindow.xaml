<Window x:Class="ManufacturingERP.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ManufacturingERP.Desktop.ViewModels"
        xmlns:views="clr-namespace:ManufacturingERP.Desktop.Views"
        Title="Manufacturing ERP" Height="920" Width="1620" MinHeight="760" MinWidth="1280"
        WindowStartupLocation="CenterScreen" Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductsViewModel}"><views:ProductsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomersViewModel}"><views:CustomersView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SuppliersViewModel}"><views:SuppliersView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:VehiclesViewModel}"><views:VehiclesView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:WarehousesViewModel}"><views:WarehousesView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:RoutesViewModel}"><views:RoutesView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:VehicleSalesViewModel}"><views:VehicleSalesView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PosSalesViewModel}"><views:PosSalesView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CollectionsViewModel}"><views:CollectionsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:MobileSyncViewModel}"><views:MobileSyncView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProcurementViewModel}"><views:ProcurementView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:Phase3ProcurementViewModel}"><views:Phase3ProcurementView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SupplierPaymentsViewModel}"><views:SupplierPaymentsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:WarehouseViewModel}"><views:WarehouseView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductionViewModel}"><views:ProductionView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductionCostingViewModel}"><views:ProductionCostingView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AccountingViewModel}"><views:AccountingView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LedgersViewModel}"><views:LedgersView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}"><views:ReportsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportViewerViewModel}"><views:ReportViewerView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:UserManagementViewModel}"><views:UserManagementView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditLogsViewModel}"><views:AuditLogsView /></DataTemplate>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="D1" Modifiers="Control" Command="{Binding ShowDashboardCommand}" />
        <KeyBinding Key="D2" Modifiers="Control" Command="{Binding ShowCustomersCommand}" />
        <KeyBinding Key="D3" Modifiers="Control" Command="{Binding ShowPosSalesCommand}" />
        <KeyBinding Key="D4" Modifiers="Control" Command="{Binding ShowProcurementCommand}" />
        <KeyBinding Key="D5" Modifiers="Control" Command="{Binding ShowWarehouseCommand}" />
        <KeyBinding Key="D6" Modifiers="Control" Command="{Binding ShowAccountingCommand}" />
        <KeyBinding Key="D7" Modifiers="Control" Command="{Binding ShowReportsCommand}" />
        <KeyBinding Key="L" Modifiers="Control" Command="{Binding ShowLedgersCommand}" />
        <KeyBinding Key="U" Modifiers="Control" Command="{Binding ShowUsersCommand}" />
        <KeyBinding Key="R" Modifiers="Control,Shift" Command="{Binding ShowReportViewerCommand}" />
    </Window.InputBindings>

    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="336" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" CornerRadius="28" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Background="#214467" CornerRadius="14" Padding="10,6" HorizontalAlignment="Left">
                        <TextBlock Text="ERP" Foreground="White" FontWeight="Bold" />
                    </Border>
                    <TextBlock Text="Manufacturing ERP" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,14,0,0" />
                    <TextBlock Text="Operations workspace for sales, supply chain, production, and finance."
                               Foreground="#CBD5E1"
                               Margin="0,8,0,14"
                               TextWrapping="Wrap" />
                    <Border Background="{StaticResource SidebarAccentBrush}" CornerRadius="18" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="Signed In As" Foreground="#94A3B8" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding CurrentUserDisplay}" Foreground="White" Margin="0,4,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#FDE68A" Margin="0,10,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,18,0,18">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SidebarSectionText}" Text="Sales &amp; Distribution" />
                        <Button Content="Dashboard" Style="{StaticResource SidebarButton}" Command="{Binding ShowDashboardCommand}" />
                        <Button Content="Products" Style="{StaticResource SidebarButton}" Command="{Binding ShowProductsCommand}" Visibility="{Binding CanManageSales, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Customers" Style="{StaticResource SidebarButton}" Command="{Binding ShowCustomersCommand}" Visibility="{Binding CanManageSales, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Vehicle Sales" Style="{StaticResource SidebarButton}" Command="{Binding ShowVehicleSalesCommand}" Visibility="{Binding CanManageSales, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="POS Sales" Style="{StaticResource SidebarButton}" Command="{Binding ShowPosSalesCommand}" Visibility="{Binding CanManageSales, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Collections" Style="{StaticResource SidebarButton}" Command="{Binding ShowCollectionsCommand}" Visibility="{Binding CanManageSales, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <TextBlock Style="{StaticResource SidebarSectionText}" Text="Master Data" />
                        <Button Content="Suppliers" Style="{StaticResource SidebarButton}" Command="{Binding ShowSuppliersCommand}" Visibility="{Binding CanManageAdmin, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Vehicles" Style="{StaticResource SidebarButton}" Command="{Binding ShowVehiclesCommand}" Visibility="{Binding CanManageAdmin, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Warehouses" Style="{StaticResource SidebarButton}" Command="{Binding ShowWarehousesCommand}" Visibility="{Binding CanManageAdmin, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Routes" Style="{StaticResource SidebarButton}" Command="{Binding ShowRoutesCommand}" Visibility="{Binding CanManageAdmin, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <TextBlock Style="{StaticResource SidebarSectionText}" Text="Supply &amp; Operations" />
                        <Button Content="Procurement" Style="{StaticResource SidebarButton}" Command="{Binding ShowProcurementCommand}" Visibility="{Binding CanManageAdmin, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Supplier Invoices &amp; Returns" Style="{StaticResource SidebarButton}" Command="{Binding ShowSupplierFinanceCommand}" Visibility="{Binding CanManageAccounting, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Supplier Payments" Style="{StaticResource SidebarButton}" Command="{Binding ShowSupplierPaymentsCommand}" Visibility="{Binding CanManageAccounting, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Warehouse" Style="{StaticResource SidebarButton}" Command="{Binding ShowWarehouseCommand}" Visibility="{Binding CanManageWarehouse, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Production" Style="{StaticResource SidebarButton}" Command="{Binding ShowProductionCommand}" Visibility="{Binding CanManageProduction, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Production Costing" Style="{StaticResource SidebarButton}" Command="{Binding ShowProductionCostingCommand}" Visibility="{Binding CanManageProduction, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Mobile Sync" Style="{StaticResource SidebarButton}" Command="{Binding ShowMobileSyncCommand}" Visibility="{Binding CanManageSales, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <TextBlock Style="{StaticResource SidebarSectionText}" Text="Finance &amp; Reporting" />
                        <Button Content="Accounting" Style="{StaticResource SidebarButton}" Command="{Binding ShowAccountingCommand}" Visibility="{Binding CanManageAccounting, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Ledgers" Style="{StaticResource SidebarButton}" Command="{Binding ShowLedgersCommand}" Visibility="{Binding CanManageAccounting, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Reports" Style="{StaticResource SidebarButton}" Command="{Binding ShowReportsCommand}" Visibility="{Binding CanViewReports, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Report Center" Style="{StaticResource SidebarButton}" Command="{Binding ShowReportViewerCommand}" Visibility="{Binding CanViewReports, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Users" Style="{StaticResource SidebarButton}" Command="{Binding ShowUsersCommand}" Visibility="{Binding CanManageAdmin, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Audit Logs" Style="{StaticResource SidebarButton}" Command="{Binding ShowAuditLogsCommand}" Visibility="{Binding CanManageAdmin, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Ctrl+1 Dashboard  Ctrl+3 POS  Ctrl+6 Accounting"
                               Foreground="#94A3B8"
                               TextWrapping="Wrap" />
                    <TextBlock Text="Ctrl+7 Reports  Ctrl+L Ledgers  Ctrl+U Users  Ctrl+Shift+R Report Center"
                               Foreground="#94A3B8"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Background="{StaticResource ContentPanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="28"
                Padding="24">
            <ContentControl Content="{Binding CurrentView}" />
        </Border>
    </Grid>
</Window>
