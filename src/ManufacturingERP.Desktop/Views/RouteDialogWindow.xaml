<Window x:Class="ManufacturingERP.Desktop.Views.RouteDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Route"
        Height="520"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EAF1FA">
    <Grid Margin="18">
        <Border Style="{StaticResource SectionCard}" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Route Profile" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Set route identity, territory coverage, and operational notes."
                               Style="{StaticResource PageSubtitleText}" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Code" Style="{StaticResource FormLabel}" />
                    <TextBox Text="{Binding Code}" materialDesign:HintAssist.Hint="Route code" />
                    <TextBlock Text="Name" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                    <TextBox Text="{Binding Name}" materialDesign:HintAssist.Hint="Route name" />
                    <TextBlock Text="Territory" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                    <TextBox Text="{Binding Territory}" materialDesign:HintAssist.Hint="Territory" />
                    <TextBlock Text="Notes" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                    <TextBox Text="{Binding Notes}" Height="100" AcceptsReturn="True" TextWrapping="Wrap" materialDesign:HintAssist.Hint="Operational notes" />
                    <CheckBox Content="Active" IsChecked="{Binding IsActive}" Margin="0,16,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="Save" Width="110" Margin="0,0,8,0" Click="Save_Click" />
                    <Button Content="Cancel" Width="110" Click="Cancel_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
