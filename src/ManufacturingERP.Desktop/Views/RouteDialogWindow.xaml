<Window x:Class="ManufacturingERP.Desktop.Views.RouteDialogWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Route" Height="540" Width="520" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="{StaticResource AppBackgroundBrush}">
    <Border Margin="20" Style="{StaticResource ViewRootCard}">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Route" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="Define route identity, territory, and operating notes with consistent spacing." Style="{StaticResource PageSubtitleText}" Margin="0,0,0,20" />
                    <TextBlock Text="Code" Style="{StaticResource FormLabel}" />
                    <TextBox Text="{Binding Code}" />
                    <TextBlock Text="Name" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Text="{Binding Name}" />
                    <TextBlock Text="Territory" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Text="{Binding Territory}" />
                    <TextBlock Text="Notes" Style="{StaticResource FormLabel}" Margin="0,12,0,6" />
                    <TextBox Height="96" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Notes}" />
                    <CheckBox Content="Active" IsChecked="{Binding IsActive}" />
                </StackPanel>
            </ScrollViewer>
            <WrapPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Save" Width="110" Style="{StaticResource PrimaryActionButton}" Click="Save_Click" />
                <Button Content="Cancel" Width="110" Style="{StaticResource SecondaryActionButton}" Margin="0" Click="Cancel_Click" />
            </WrapPanel>
        </Grid>
    </Border>
</Window>
