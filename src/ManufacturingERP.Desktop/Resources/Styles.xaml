<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

    <SolidColorBrush x:Key="ShellBgBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="ShellPanelBrush" Color="#111827" />
    <SolidColorBrush x:Key="PageBgBrush" Color="#F3F6FB" />
    <SolidColorBrush x:Key="CardBgBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="PrimarySoftBrush" Color="#DBEAFE" />
    <SolidColorBrush x:Key="AccentBrush" Color="#0F766E" />
    <SolidColorBrush x:Key="WarningBrush" Color="#C2410C" />
    <SolidColorBrush x:Key="DangerBrush" Color="#B91C1C" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
    <SolidColorBrush x:Key="HeadingBrush" Color="#0F172A" />

    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="White" />
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="White" />
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="MinHeight" Value="38" />
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="SecondaryActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}" />
    </Style>

    <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="Padding" Value="16,11" />
        <Setter Property="Foreground" Value="#E5E7EB" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1E293B" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SidebarSectionText" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,18,0,8" />
        <Setter Property="Foreground" Value="#94A3B8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="SectionCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Margin" Value="0,0,0,18" />
    </Style>

    <Style x:Key="CardTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="Foreground" Value="{StaticResource HeadingBrush}" />
    </Style>

    <Style x:Key="MetricValueText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource HeadingBrush}" />
    </Style>

    <Style x:Key="FormLabel" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,12,0,4" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#334155" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="PageTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource HeadingBrush}" />
    </Style>

    <Style x:Key="SubtleCaptionText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="StatusTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,10,0,0" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SearchTextBox" TargetType="TextBox">
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Margin" Value="0,12,0,0" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Background" Value="#F8FAFC" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="RowHeight" Value="36" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="#E5E7EB" />
        <Setter Property="VerticalGridLinesBrush" Value="#F8FAFC" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="AlternatingRowBackground" Value="#F8FAFC" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#EFF6FF" />
        <Setter Property="Foreground" Value="{StaticResource HeadingBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="BorderBrush" Value="#DBEAFE" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="Height" Value="6" />
        <Setter Property="Margin" Value="0,0,0,14" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="Background" Value="#DBEAFE" />
    </Style>
</ResourceDictionary>
