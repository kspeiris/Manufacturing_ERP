<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F6FB" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8E1EC" />
    <SolidColorBrush x:Key="InkBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="InkMutedBrush" Color="#475569" />
    <SolidColorBrush x:Key="StatusBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="SidebarBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="SidebarAccentBrush" Color="#1E293B" />

    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style TargetType="PasswordBox" BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}">
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="MinHeight" Value="44" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Margin" Value="0,12,0,0" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="#E5EAF1" />
        <Setter Property="VerticalGridLinesBrush" Value="#E5EAF1" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="RowHeight" Value="40" />
        <Setter Property="ColumnHeaderHeight" Value="42" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource SurfaceAltBrush}" />
    </Style>

    <Style TargetType="ListBox" BasedOn="{StaticResource MaterialDesignListBox}">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6" />
    </Style>

    <Style x:Key="PageTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="PageSubtitleText" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,6,0,0" />
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CardTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="19" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,14" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="MetricValueText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    </Style>

    <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="#E2E8F0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SidebarSectionText" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,18,0,8" />
        <Setter Property="Foreground" Value="#94A3B8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SectionCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style x:Key="ViewRootCard" TargetType="Border" BasedOn="{StaticResource SectionCard}">
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style x:Key="FormLabel" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CaptionText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="StatusMessageText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource StatusBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,12,0,0" />
    </Style>

    <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SecondaryActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="DangerActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#B91C1C" />
        <Setter Property="BorderBrush" Value="#FECACA" />
    </Style>
</ResourceDictionary>
