<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <Style x:Key="CardTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="Foreground" Value="#111827" />
    </Style>

    <Style x:Key="MetricValueText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#0F172A" />
    </Style>

    <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Foreground" Value="#E5E7EB" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="SidebarSectionText" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,18,0,8" />
        <Setter Property="Foreground" Value="#94A3B8" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SectionCard" TargetType="Border">
        <Setter Property="Background" Value="White" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style x:Key="FormLabel" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#334155" />
    </Style>
</ResourceDictionary>
