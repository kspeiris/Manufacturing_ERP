<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

    <SolidColorBrush x:Key="AppCanvasBrush" Color="#DCE7F5" />
    <SolidColorBrush x:Key="AppPanelBrush" Color="#EEF4FB" />
    <SolidColorBrush x:Key="AppCardBrush" Color="#FCFEFF" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="#DCE7F5" />
    <SolidColorBrush x:Key="AppPrimaryBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="AppPrimaryHoverBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="AppDangerBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="AppDangerHoverBrush" Color="#B91C1C" />
    <SolidColorBrush x:Key="AppMutedTextBrush" Color="#64748B" />
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource AppCanvasBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="Auto" />
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="PanningMode" Value="VerticalOnly" />
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Margin" Value="0" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="MinWidth" Value="84" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="{StaticResource AppPrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource AppPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AppPrimaryHoverBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AppPrimaryHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                        </Trigger>
                        <Trigger Property="Content" Value="Cancel">
                            <Setter TargetName="Root" Property="Background" Value="#E2E8F0" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="#CBD5E1" />
                            <Setter Property="Foreground" Value="#334155" />
                        </Trigger>
                        <Trigger Property="Content" Value="Delete">
                            <Setter TargetName="Root" Property="Background" Value="#FEE2E2" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="#FCA5A5" />
                            <Setter Property="Foreground" Value="{StaticResource AppDangerBrush}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Content" Value="Delete" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="#FECACA" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="#F87171" />
                            <Setter Property="Foreground" Value="{StaticResource AppDangerHoverBrush}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Content" Value="Cancel" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="#CBD5E1" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="#94A3B8" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Background" Value="#FFFFFF" />
    </Style>

    <Style TargetType="PasswordBox" BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}">
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Background" Value="#FFFFFF" />
    </Style>

    <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Background" Value="#FFFFFF" />
    </Style>

    <Style TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="#334155" />
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowBackground" Value="#FFFFFF" />
        <Setter Property="AlternatingRowBackground" Value="#F8FBFF" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="#E5EDF7" />
        <Setter Property="VerticalGridLinesBrush" Value="#00000000" />
        <Setter Property="RowHeight" Value="36" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#EAF1FA" />
        <Setter Property="Foreground" Value="#334155" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="BorderBrush" Value="#DCE7F5" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Foreground" Value="#1E293B" />
        <Setter Property="BorderBrush" Value="#E5EDF7" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style x:Key="CardTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Foreground" Value="#111827" />
    </Style>

    <Style x:Key="MetricValueText" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#0F172A" />
    </Style>

    <Style x:Key="PageTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#0F172A" />
    </Style>

    <Style x:Key="PageSubtitleText" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="Foreground" Value="#64748B" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Foreground" Value="#D6E1F5" />
        <Setter Property="Background" Value="#00000000" />
        <Setter Property="BorderBrush" Value="#00000000" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#1E293B" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#2563EB" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="#60A5FA" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarSectionText" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,20,0,10" />
        <Setter Property="Foreground" Value="#94A3B8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="SectionCard" TargetType="Border">
        <Setter Property="Background" Value="#FCFEFF" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="Margin" Value="0,0,0,14" />
        <Setter Property="BorderBrush" Value="#DCE7F5" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="UtilityPanel" TargetType="Border" BasedOn="{StaticResource SectionCard}">
        <Setter Property="Background" Value="#F8FBFF" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="MinHeight" Value="108" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style x:Key="InlineStatCard" TargetType="Border" BasedOn="{StaticResource SectionCard}">
        <Setter Property="Background" Value="#F8FBFF" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="MinWidth" Value="180" />
        <Setter Property="MinHeight" Value="108" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style x:Key="InlineStatLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#64748B" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="InlineStatValue" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,6,0,0" />
        <Setter Property="Foreground" Value="#0F172A" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="HeroCard" TargetType="Border" BasedOn="{StaticResource SectionCard}">
        <Setter Property="Background" Value="#0F172A" />
        <Setter Property="BorderBrush" Value="#1E3A8A" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <Style x:Key="MetricCard" TargetType="Border" BasedOn="{StaticResource SectionCard}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="MinHeight" Value="132" />
    </Style>

    <Style x:Key="PageActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="MinWidth" Value="104" />
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="Margin" Value="0,0,10,0" />
    </Style>

    <Style x:Key="PageDangerButton" TargetType="Button" BasedOn="{StaticResource PageActionButton}">
        <Setter Property="Background" Value="#FEE2E2" />
        <Setter Property="BorderBrush" Value="#FCA5A5" />
        <Setter Property="Foreground" Value="#DC2626" />
    </Style>

    <Style x:Key="ResponsiveTileCard" TargetType="Border" BasedOn="{StaticResource SectionCard}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="Margin" Value="0,0,16,16" />
        <Setter Property="Width" Value="248" />
    </Style>

    <Style x:Key="HeroEyebrowText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#93C5FD" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="HeroTitleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="HeroBodyText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#CBD5E1" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="FormLabel" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#334155" />
    </Style>
</ResourceDictionary>
